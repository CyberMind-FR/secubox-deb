#!/bin/bash
# ══════════════════════════════════════════════════════════════════
#  secubox-kiosk-launcher — X11 Kiosk via nodm
#  Uses nodm display manager for reliable X11 startup
#  Compatible with VirtualBox, VMware, QEMU, bare metal
# ══════════════════════════════════════════════════════════════════
set -euo pipefail

readonly KIOSK_USER="secubox-kiosk"
readonly KIOSK_HOME="/home/secubox-kiosk"
readonly LOG_TAG="secubox-kiosk"

log() { echo "[kiosk] $*" >&2; logger -t "$LOG_TAG" "$*" 2>/dev/null || true; }
err() { echo "[kiosk] ERROR: $*" >&2; logger -t "$LOG_TAG" -p err "$*" 2>/dev/null || true; }

# ══════════════════════════════════════════════════════════════════
# DEBUG: Generate diagnostic report for VirtualBox/VM troubleshooting
# ══════════════════════════════════════════════════════════════════
readonly DEBUG_REPORT="/tmp/kiosk-debug-$(date +%Y%m%d-%H%M%S).log"

generate_debug_report() {
    local report="$DEBUG_REPORT"
    {
        echo "═══════════════════════════════════════════════════════════════"
        echo "SecuBox Kiosk Debug Report - $(date -Iseconds)"
        echo "═══════════════════════════════════════════════════════════════"
        echo ""

        echo "▶ SYSTEM INFO:"
        echo "  Hostname: $(hostname)"
        echo "  Kernel: $(uname -r)"
        echo "  Architecture: $(uname -m)"
        echo ""

        echo "▶ VIRTUALIZATION:"
        echo "  systemd-detect-virt: $(systemd-detect-virt 2>/dev/null || echo 'N/A')"
        echo "  DMI Product: $(cat /sys/class/dmi/id/product_name 2>/dev/null || echo 'N/A')"
        echo "  DMI Vendor: $(cat /sys/class/dmi/id/sys_vendor 2>/dev/null || echo 'N/A')"
        echo ""

        echo "▶ GRAPHICS HARDWARE:"
        lspci 2>/dev/null | grep -iE "vga|display|graphics|3d" || echo "  No PCI graphics found"
        echo ""

        echo "▶ DRM/KMS DEVICES:"
        ls -la /dev/dri/ 2>/dev/null || echo "  No DRM devices"
        echo ""

        echo "▶ FRAMEBUFFER:"
        ls -la /dev/fb* 2>/dev/null || echo "  No framebuffer devices"
        cat /sys/class/graphics/fb0/virtual_size 2>/dev/null && echo "(fb0 virtual size)"
        echo ""

        echo "▶ TTY STATUS:"
        fgconsole 2>/dev/null && echo "(current VT)"
        cat /sys/class/tty/tty0/active 2>/dev/null && echo "(active tty)"
        who 2>/dev/null | head -5
        echo ""

        echo "▶ KIOSK FLAG FILES:"
        ls -la /var/lib/secubox/.kiosk* 2>/dev/null || echo "  No kiosk flags found"
        echo ""

        echo "▶ KIOSK USER:"
        id "$KIOSK_USER" 2>/dev/null || echo "  User not found: $KIOSK_USER"
        ls -la "$KIOSK_HOME"/.x* 2>/dev/null || echo "  No xsession files"
        echo ""

        echo "▶ X11 CONFIG:"
        ls -la /etc/X11/xorg.conf.d/ 2>/dev/null || echo "  No xorg.conf.d"
        cat /etc/X11/xorg.conf.d/*.conf 2>/dev/null || true
        cat /etc/X11/Xwrapper.config 2>/dev/null || echo "  No Xwrapper.config"
        echo ""

        echo "▶ LOADED KERNEL MODULES (video-related):"
        lsmod 2>/dev/null | grep -iE "drm|vmware|vbox|i915|nouveau|amdgpu|fb" || echo "  None"
        echo ""

        echo "▶ X11 BINARIES:"
        which Xorg 2>/dev/null || echo "  Xorg not found!"
        which xinit 2>/dev/null || echo "  xinit not found!"
        which chromium 2>/dev/null || echo "  chromium not found!"
        echo ""

        echo "▶ SYSTEMD KIOSK SERVICE:"
        systemctl status secubox-kiosk.service --no-pager 2>&1 | head -20
        echo ""

        echo "▶ RELEVANT JOURNAL LOGS (last 50 lines):"
        journalctl -t secubox-kiosk --no-pager -n 50 2>/dev/null || echo "  No journal entries"
        echo ""

        echo "▶ XORG LOG (if exists):"
        tail -100 /var/log/Xorg.0.log 2>/dev/null || echo "  No Xorg.0.log yet"
        echo ""

        echo "═══════════════════════════════════════════════════════════════"
        echo "End of Debug Report"
        echo "═══════════════════════════════════════════════════════════════"
    } >> "$report" 2>&1

    log "Debug report written to: $report"

    # Also symlink as latest
    ln -sf "$report" /tmp/kiosk-debug-latest.log 2>/dev/null || true
}

# ══════════════════════════════════════════════════════════════════
# LOCK: Prevent .bash_profile's start-kiosk from running in parallel
# ══════════════════════════════════════════════════════════════════
readonly LOCK_FILE="/tmp/.kiosk-starting"
if [[ -f "$LOCK_FILE" ]]; then
    log "Lock file exists - kiosk already starting/running"
    exit 0
fi
touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"' EXIT

# ══════════════════════════════════════════════════════════════════
# STEP 1: Verify prerequisites
# ══════════════════════════════════════════════════════════════════
check_prerequisites() {
    log "Checking prerequisites..."

    [[ -f /var/lib/secubox/.kiosk-enabled ]] || {
        err "Kiosk not enabled (/var/lib/secubox/.kiosk-enabled missing)"
        exit 1
    }

    # Ensure user exists
    if ! id "$KIOSK_USER" &>/dev/null; then
        log "Creating kiosk user..."
        useradd -m -d "$KIOSK_HOME" -s /bin/bash \
            -G video,audio,input,tty,render "$KIOSK_USER" 2>/dev/null || true
    fi

    log "Prerequisites OK"
}

# ══════════════════════════════════════════════════════════════════
# STEP 2: Detect VM and configure X11 driver
# ══════════════════════════════════════════════════════════════════
configure_x11() {
    log "Configuring X11..."

    local vm_type driver="modesetting"
    vm_type=$(systemd-detect-virt 2>/dev/null || echo "none")

    # Detect graphics hardware
    if lspci 2>/dev/null | grep -qi "VMware SVGA\|VMSVGA"; then
        driver="vmware"
        log "Detected VMSVGA graphics → vmware driver"
    elif lspci 2>/dev/null | grep -qi "VirtualBox"; then
        driver="vboxvideo"
        modprobe vboxvideo 2>/dev/null || driver="modesetting"
        log "Detected VirtualBox → $driver driver"
    elif lspci 2>/dev/null | grep -qi "QXL\|Virtio"; then
        driver="modesetting"
        log "Detected QEMU/KVM → modesetting driver"
    else
        log "Using default modesetting driver"
    fi

    # Clean existing configs
    rm -f /etc/X11/xorg.conf /etc/X11/xorg.conf.d/*.conf
    mkdir -p /etc/X11/xorg.conf.d

    # Write minimal X11 config with input devices
    cat > /etc/X11/xorg.conf.d/10-kiosk.conf <<XCONF
Section "Device"
    Identifier "Kiosk Graphics"
    Driver "$driver"
EndSection

Section "ServerFlags"
    Option "DontZap" "false"
    Option "BlankTime" "0"
    Option "StandbyTime" "0"
    Option "SuspendTime" "0"
    Option "OffTime" "0"
    Option "AutoAddDevices" "true"
    Option "AllowEmptyInput" "false"
EndSection

Section "InputClass"
    Identifier "libinput keyboard"
    MatchIsKeyboard "on"
    Driver "libinput"
EndSection

Section "InputClass"
    Identifier "libinput pointer"
    MatchIsPointer "on"
    Driver "libinput"
EndSection

Section "InputClass"
    Identifier "libinput touchpad"
    MatchIsTouchpad "on"
    Driver "libinput"
EndSection
XCONF

    # Xwrapper permissions
    cat > /etc/X11/Xwrapper.config <<'XWRAP'
allowed_users=anybody
needs_root_rights=yes
XWRAP

    log "X11 configured with $driver driver"
}

# ══════════════════════════════════════════════════════════════════
# STEP 3: Determine kiosk URL
# ══════════════════════════════════════════════════════════════════
determine_url() {
    log "Determining kiosk URL..."

    local url=""
    # localhost first - always works regardless of network state
    local urls=(
        "https://localhost/"
        "https://127.0.0.1/"
        "http://localhost/"
        "http://127.0.0.1/"
    )

    # Wait for nginx (max 20s)
    for i in {1..20}; do
        systemctl is-active nginx &>/dev/null && break
        sleep 1
    done

    # Find working URL
    for test_url in "${urls[@]}"; do
        if curl -sk --connect-timeout 2 "$test_url" >/dev/null 2>&1; then
            url="$test_url"
            break
        fi
    done

    echo "${url:-https://localhost/}"
}

# ══════════════════════════════════════════════════════════════════
# STEP 4: Create kiosk session script (minimal, no optional deps)
# ══════════════════════════════════════════════════════════════════
create_session() {
    local url="$1"
    log "Creating kiosk session (URL: $url)..."

    mkdir -p "$KIOSK_HOME/.config"

    # Chromium profile directory
    mkdir -p "$KIOSK_HOME/.config/chromium"
    chown -R "$KIOSK_USER:$KIOSK_USER" "$KIOSK_HOME/.config"

    # Session script with simple splash and debug logging
    cat > "$KIOSK_HOME/.xsession" <<'XSESSION'
#!/bin/bash
# SecuBox Kiosk - X Session (v1.6.7.3)
exec >> /tmp/kiosk-session.log 2>&1
echo "=== X Session Start: $(date) ==="

export DISPLAY=${DISPLAY:-:0}
echo "DISPLAY=$DISPLAY"

# Log to syslog too
logger -t secubox-kiosk "X session starting on $DISPLAY"

# Disable screensaver
xset s off 2>/dev/null || echo "xset s off failed"
xset -dpms 2>/dev/null || echo "xset -dpms failed"
xset s noblank 2>/dev/null || echo "xset s noblank failed"

# Set dark green background as splash
xsetroot -solid "#0a1a0a" 2>/dev/null || echo "xsetroot failed"
echo "Background set"

# Wait for nginx (max 10s, non-blocking visual)
echo "Waiting for nginx..."
for i in {1..10}; do
    if curl -sk --connect-timeout 1 https://localhost/ >/dev/null 2>&1; then
        echo "nginx ready after ${i}s"
        break
    fi
    echo "  waiting... $i"
    sleep 1
done

# Determine URL
URL="https://localhost/"
for test_url in "https://localhost/" "https://127.0.0.1/" "http://localhost/"; do
    if curl -sk --connect-timeout 2 "$test_url" >/dev/null 2>&1; then
        URL="$test_url"
        echo "URL found: $URL"
        break
    fi
done

# Detect screen resolution for explicit window sizing
# xrandr returns something like "1920x1080+0+0" for connected displays
RESOLUTION=$(xrandr 2>/dev/null | grep -oP '\d+x\d+\+0\+0' | head -1 | cut -d'+' -f1)
if [[ -z "$RESOLUTION" ]]; then
    # Fallback: try to get from primary display
    RESOLUTION=$(xrandr 2>/dev/null | grep ' connected' | head -1 | grep -oP '\d+x\d+' | head -1)
fi
if [[ -z "$RESOLUTION" ]]; then
    RESOLUTION="1920x1080"  # Ultimate fallback
fi
WIDTH=$(echo "$RESOLUTION" | cut -dx -f1)
HEIGHT=$(echo "$RESOLUTION" | cut -dx -f2)
echo "Screen resolution: ${WIDTH}x${HEIGHT}"

logger -t secubox-kiosk "Launching Chromium: $URL (${WIDTH}x${HEIGHT})"
echo "Launching Chromium: $URL"

# Chromium with explicit window size for reliable fullscreen
# --kiosk is more reliable than --start-fullscreen for embedded systems
# --test-type suppresses the "unsupported flag" warning banner
exec chromium \
    --kiosk \
    --window-size=${WIDTH},${HEIGHT} \
    --window-position=0,0 \
    --no-first-run \
    --disable-gpu \
    --disable-software-rasterizer \
    --noerrdialogs \
    --disable-translate \
    --ignore-certificate-errors \
    --test-type \
    --disable-features=TranslateUI \
    --disable-infobars \
    "$URL"
XSESSION

    chmod +x "$KIOSK_HOME/.xsession"
    ln -sf .xsession "$KIOSK_HOME/.xinitrc"
    chown -R "$KIOSK_USER:$KIOSK_USER" "$KIOSK_HOME"

    log "Session script created"
}

# ══════════════════════════════════════════════════════════════════
# STEP 5: Start X11 display
# Strategy: Start Xorg as root, then run session as kiosk user
# This is the most reliable approach for kiosk systems
# ══════════════════════════════════════════════════════════════════
start_display() {
    log "Starting X11 display..."

    local kiosk_uid kiosk_gid runtime_dir xauth_file x_log
    kiosk_uid=$(id -u "$KIOSK_USER")
    kiosk_gid=$(id -g "$KIOSK_USER")
    runtime_dir="/run/user/$kiosk_uid"
    xauth_file="$KIOSK_HOME/.Xauthority"
    x_log="/var/log/Xorg.0.log"

    # DEBUG: Log VM environment
    log "▶ VM Detection:"
    log "  - systemd-detect-virt: $(systemd-detect-virt 2>/dev/null || echo 'unknown')"
    log "  - /dev/dri contents: $(ls /dev/dri/ 2>/dev/null || echo 'empty')"
    log "  - DRM modules: $(lsmod | grep -E 'drm|vmware|vbox' 2>/dev/null | awk '{print $1}' | tr '\n' ' ')"

    # Setup XDG runtime directory
    mkdir -p "$runtime_dir"
    chown "$kiosk_uid:$kiosk_gid" "$runtime_dir"
    chmod 700 "$runtime_dir"

    # Create Xauthority with magic cookie
    log "Setting up Xauthority..."
    rm -f "$xauth_file"
    touch "$xauth_file"

    # Generate X auth cookie (mcookie or fallback)
    local cookie
    cookie=$(mcookie 2>/dev/null || od -An -tx1 -N16 /dev/urandom | tr -d ' \n')
    xauth -f "$xauth_file" add :0 . "$cookie" 2>/dev/null || true
    chown "$KIOSK_USER:$KIOSK_USER" "$xauth_file"
    chmod 600 "$xauth_file"
    log "Xauthority created"

    # Pre-flight checks
    log "Pre-flight checks:"
    log "  - User: $KIOSK_USER (uid=$kiosk_uid)"
    log "  - Xauthority: $xauth_file"
    log "  - Session: $KIOSK_HOME/.xsession"

    # Check X server
    if ! command -v Xorg >/dev/null 2>&1; then
        err "Xorg not found!"
        exit 1
    fi
    log "  - X server: $(which Xorg)"

    # Kill any existing X server
    pkill -9 Xorg 2>/dev/null || true
    pkill -9 X 2>/dev/null || true
    sleep 1

    log "Starting Xorg on :0 vt7..."

    # Start X server as root in background
    # -auth uses our Xauthority so kiosk user can connect
    # -noreset keeps X running even if last client disconnects
    Xorg :0 vt7 \
        -nolisten tcp \
        -auth "$xauth_file" \
        -noreset \
        -logfile "$x_log" \
        2>&1 &

    local x_pid=$!
    log "Xorg started with PID $x_pid"

    # Wait for X to be ready (check for socket)
    local attempts=0
    while [[ $attempts -lt 30 ]]; do
        if [[ -S /tmp/.X11-unix/X0 ]]; then
            log "X11 socket ready after ${attempts}s"
            break
        fi
        sleep 1
        ((attempts++))
    done

    # Verify X is running
    if ! kill -0 "$x_pid" 2>/dev/null; then
        err "Xorg process died! Check $x_log"
        err "▶ XORG FAILURE DEBUG:"
        {
            echo ""
            echo "════════ XORG FAILURE REPORT ════════"
            echo "Timestamp: $(date -Iseconds)"
            echo ""
            echo "▶ Xorg.0.log (last 100 lines):"
            tail -100 "$x_log" 2>/dev/null || echo "No log file"
            echo ""
            echo "▶ dmesg (graphics related):"
            dmesg 2>/dev/null | grep -iE "drm|gpu|vbox|vmware|display" | tail -30
            echo ""
            echo "▶ Kernel modules:"
            lsmod | grep -iE "drm|vbox|vmware|i915|nouveau" || echo "None found"
            echo ""
        } >> "$DEBUG_REPORT" 2>&1
        log "Debug info appended to: $DEBUG_REPORT"
        exit 1
    fi

    if [[ ! -S /tmp/.X11-unix/X0 ]]; then
        err "X11 socket not created after 30s"
        err "▶ X11 SOCKET DEBUG:"
        {
            echo ""
            echo "════════ X11 SOCKET FAILURE ════════"
            echo "Timestamp: $(date -Iseconds)"
            echo "Xorg PID: $x_pid ($(kill -0 $x_pid 2>&1 && echo 'running' || echo 'dead'))"
            echo ""
            echo "▶ /tmp/.X11-unix/:"
            ls -la /tmp/.X11-unix/ 2>/dev/null || echo "Directory doesn't exist"
            echo ""
            echo "▶ Xorg.0.log:"
            tail -100 "$x_log" 2>/dev/null || echo "No log file"
            echo ""
            echo "▶ VT status:"
            fgconsole 2>/dev/null && echo "(fgconsole)"
            cat /sys/class/tty/tty0/active 2>/dev/null && echo "(active tty)"
        } >> "$DEBUG_REPORT" 2>&1
        log "Debug info appended to: $DEBUG_REPORT"
        exit 1
    fi

    log "X server running, launching session as $KIOSK_USER..."

    # Switch to VT7 explicitly
    chvt 7 2>/dev/null || true

    # Run the session as kiosk user
    # exec replaces this process - systemd keeps tracking the session
    exec su -l "$KIOSK_USER" -c "
        export DISPLAY=:0
        export XAUTHORITY='$xauth_file'
        export XDG_RUNTIME_DIR='$runtime_dir'
        export HOME='$KIOSK_HOME'
        cd '$KIOSK_HOME'
        exec '$KIOSK_HOME/.xsession'
    "
}

# ══════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════
main() {
    log "════════════════════════════════════════════════"
    log "SecuBox Kiosk Launcher v2.6 (1.6.7.3) - Debug Enabled"
    log "════════════════════════════════════════════════"

    # Generate debug report FIRST for troubleshooting
    generate_debug_report

    check_prerequisites
    configure_x11

    local url
    url=$(determine_url)

    create_session "$url"
    start_display
}

main "$@"
