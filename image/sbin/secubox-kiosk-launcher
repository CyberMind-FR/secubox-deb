#!/bin/bash
# ══════════════════════════════════════════════════════════════════
#  secubox-kiosk-launcher — X11 Kiosk via nodm
#  Uses nodm display manager for reliable X11 startup
#  Compatible with VirtualBox, VMware, QEMU, bare metal
# ══════════════════════════════════════════════════════════════════
set -euo pipefail

readonly KIOSK_USER="secubox-kiosk"
readonly KIOSK_HOME="/home/secubox-kiosk"
readonly LOG_TAG="secubox-kiosk"

log() { echo "[kiosk] $*" >&2; logger -t "$LOG_TAG" "$*" 2>/dev/null || true; }
err() { echo "[kiosk] ERROR: $*" >&2; logger -t "$LOG_TAG" -p err "$*" 2>/dev/null || true; }

# ══════════════════════════════════════════════════════════════════
# STEP 1: Verify prerequisites
# ══════════════════════════════════════════════════════════════════
check_prerequisites() {
    log "Checking prerequisites..."

    [[ -f /var/lib/secubox/.kiosk-enabled ]] || {
        err "Kiosk not enabled (/var/lib/secubox/.kiosk-enabled missing)"
        exit 1
    }

    # Ensure user exists
    if ! id "$KIOSK_USER" &>/dev/null; then
        log "Creating kiosk user..."
        useradd -m -d "$KIOSK_HOME" -s /bin/bash \
            -G video,audio,input,tty,render "$KIOSK_USER" 2>/dev/null || true
    fi

    log "Prerequisites OK"
}

# ══════════════════════════════════════════════════════════════════
# STEP 2: Detect VM and configure X11 driver
# ══════════════════════════════════════════════════════════════════
configure_x11() {
    log "Configuring X11..."

    local vm_type driver="modesetting"
    vm_type=$(systemd-detect-virt 2>/dev/null || echo "none")

    # Detect graphics hardware
    if lspci 2>/dev/null | grep -qi "VMware SVGA\|VMSVGA"; then
        driver="vmware"
        log "Detected VMSVGA graphics → vmware driver"
    elif lspci 2>/dev/null | grep -qi "VirtualBox"; then
        driver="vboxvideo"
        modprobe vboxvideo 2>/dev/null || driver="modesetting"
        log "Detected VirtualBox → $driver driver"
    elif lspci 2>/dev/null | grep -qi "QXL\|Virtio"; then
        driver="modesetting"
        log "Detected QEMU/KVM → modesetting driver"
    else
        log "Using default modesetting driver"
    fi

    # Clean existing configs
    rm -f /etc/X11/xorg.conf /etc/X11/xorg.conf.d/*.conf
    mkdir -p /etc/X11/xorg.conf.d

    # Write minimal X11 config with input devices
    cat > /etc/X11/xorg.conf.d/10-kiosk.conf <<XCONF
Section "Device"
    Identifier "Kiosk Graphics"
    Driver "$driver"
EndSection

Section "ServerFlags"
    Option "DontZap" "false"
    Option "BlankTime" "0"
    Option "StandbyTime" "0"
    Option "SuspendTime" "0"
    Option "OffTime" "0"
    Option "AutoAddDevices" "true"
    Option "AllowEmptyInput" "false"
EndSection

Section "InputClass"
    Identifier "libinput keyboard"
    MatchIsKeyboard "on"
    Driver "libinput"
EndSection

Section "InputClass"
    Identifier "libinput pointer"
    MatchIsPointer "on"
    Driver "libinput"
EndSection

Section "InputClass"
    Identifier "libinput touchpad"
    MatchIsTouchpad "on"
    Driver "libinput"
EndSection
XCONF

    # Xwrapper permissions
    cat > /etc/X11/Xwrapper.config <<'XWRAP'
allowed_users=anybody
needs_root_rights=yes
XWRAP

    log "X11 configured with $driver driver"
}

# ══════════════════════════════════════════════════════════════════
# STEP 3: Determine kiosk URL
# ══════════════════════════════════════════════════════════════════
determine_url() {
    log "Determining kiosk URL..."

    local url=""
    # localhost first - always works regardless of network state
    local urls=(
        "https://localhost/"
        "https://127.0.0.1/"
        "http://localhost/"
        "http://127.0.0.1/"
    )

    # Wait for nginx (max 20s)
    for i in {1..20}; do
        systemctl is-active nginx &>/dev/null && break
        sleep 1
    done

    # Find working URL
    for test_url in "${urls[@]}"; do
        if curl -sk --connect-timeout 2 "$test_url" >/dev/null 2>&1; then
            url="$test_url"
            break
        fi
    done

    echo "${url:-https://localhost/}"
}

# ══════════════════════════════════════════════════════════════════
# STEP 4: Create kiosk session script (minimal, no optional deps)
# ══════════════════════════════════════════════════════════════════
create_session() {
    local url="$1"
    log "Creating kiosk session (URL: $url)..."

    mkdir -p "$KIOSK_HOME/.config"

    # Chromium profile directory
    mkdir -p "$KIOSK_HOME/.config/chromium"
    chown -R "$KIOSK_USER:$KIOSK_USER" "$KIOSK_HOME/.config"

    # Session script with simple splash and debug logging
    cat > "$KIOSK_HOME/.xsession" <<'XSESSION'
#!/bin/bash
# SecuBox Kiosk - X Session (v1.6.6)
exec >> /tmp/kiosk-session.log 2>&1
echo "=== X Session Start: $(date) ==="

export DISPLAY=${DISPLAY:-:0}
echo "DISPLAY=$DISPLAY"

# Log to syslog too
logger -t secubox-kiosk "X session starting on $DISPLAY"

# Disable screensaver
xset s off 2>/dev/null || echo "xset s off failed"
xset -dpms 2>/dev/null || echo "xset -dpms failed"
xset s noblank 2>/dev/null || echo "xset s noblank failed"

# Set dark green background as splash
xsetroot -solid "#0a1a0a" 2>/dev/null || echo "xsetroot failed"
echo "Background set"

# Wait for nginx (max 10s, non-blocking visual)
echo "Waiting for nginx..."
for i in {1..10}; do
    if curl -sk --connect-timeout 1 https://localhost/ >/dev/null 2>&1; then
        echo "nginx ready after ${i}s"
        break
    fi
    echo "  waiting... $i"
    sleep 1
done

# Determine URL
URL="https://localhost/"
for test_url in "https://localhost/" "https://127.0.0.1/" "http://localhost/"; do
    if curl -sk --connect-timeout 2 "$test_url" >/dev/null 2>&1; then
        URL="$test_url"
        echo "URL found: $URL"
        break
    fi
done

logger -t secubox-kiosk "Launching Chromium: $URL"
echo "Launching Chromium: $URL"

# Chromium with minimal flags
# --test-type suppresses the "unsupported flag" warning banner
exec chromium \
    --start-fullscreen \
    --no-first-run \
    --disable-gpu \
    --disable-software-rasterizer \
    --noerrdialogs \
    --disable-translate \
    --ignore-certificate-errors \
    --test-type \
    --disable-features=TranslateUI \
    --disable-infobars \
    --window-position=0,0 \
    "$URL"
XSESSION

    chmod +x "$KIOSK_HOME/.xsession"
    ln -sf .xsession "$KIOSK_HOME/.xinitrc"
    chown -R "$KIOSK_USER:$KIOSK_USER" "$KIOSK_HOME"

    log "Session script created"
}

# ══════════════════════════════════════════════════════════════════
# STEP 5: Start X11 display
# Strategy: Start Xorg as root, then run session as kiosk user
# This is the most reliable approach for kiosk systems
# ══════════════════════════════════════════════════════════════════
start_display() {
    log "Starting X11 display..."

    local kiosk_uid kiosk_gid runtime_dir xauth_file x_log
    kiosk_uid=$(id -u "$KIOSK_USER")
    kiosk_gid=$(id -g "$KIOSK_USER")
    runtime_dir="/run/user/$kiosk_uid"
    xauth_file="$KIOSK_HOME/.Xauthority"
    x_log="/var/log/Xorg.0.log"

    # Setup XDG runtime directory
    mkdir -p "$runtime_dir"
    chown "$kiosk_uid:$kiosk_gid" "$runtime_dir"
    chmod 700 "$runtime_dir"

    # Create Xauthority with magic cookie
    log "Setting up Xauthority..."
    rm -f "$xauth_file"
    touch "$xauth_file"

    # Generate X auth cookie (mcookie or fallback)
    local cookie
    cookie=$(mcookie 2>/dev/null || od -An -tx1 -N16 /dev/urandom | tr -d ' \n')
    xauth -f "$xauth_file" add :0 . "$cookie" 2>/dev/null || true
    chown "$KIOSK_USER:$KIOSK_USER" "$xauth_file"
    chmod 600 "$xauth_file"
    log "Xauthority created"

    # Pre-flight checks
    log "Pre-flight checks:"
    log "  - User: $KIOSK_USER (uid=$kiosk_uid)"
    log "  - Xauthority: $xauth_file"
    log "  - Session: $KIOSK_HOME/.xsession"

    # Check X server
    if ! command -v Xorg >/dev/null 2>&1; then
        err "Xorg not found!"
        exit 1
    fi
    log "  - X server: $(which Xorg)"

    # Kill any existing X server
    pkill -9 Xorg 2>/dev/null || true
    pkill -9 X 2>/dev/null || true
    sleep 1

    log "Starting Xorg on :0 vt7..."

    # Start X server as root in background
    # -auth uses our Xauthority so kiosk user can connect
    # -noreset keeps X running even if last client disconnects
    Xorg :0 vt7 \
        -nolisten tcp \
        -auth "$xauth_file" \
        -noreset \
        -logfile "$x_log" \
        2>&1 &

    local x_pid=$!
    log "Xorg started with PID $x_pid"

    # Wait for X to be ready (check for socket)
    local attempts=0
    while [[ $attempts -lt 30 ]]; do
        if [[ -S /tmp/.X11-unix/X0 ]]; then
            log "X11 socket ready after ${attempts}s"
            break
        fi
        sleep 1
        ((attempts++))
    done

    # Verify X is running
    if ! kill -0 "$x_pid" 2>/dev/null; then
        err "Xorg process died! Check $x_log"
        tail -50 "$x_log" 2>/dev/null || true
        exit 1
    fi

    if [[ ! -S /tmp/.X11-unix/X0 ]]; then
        err "X11 socket not created after 30s"
        tail -50 "$x_log" 2>/dev/null || true
        exit 1
    fi

    log "X server running, launching session as $KIOSK_USER..."

    # Switch to VT7 explicitly
    chvt 7 2>/dev/null || true

    # Run the session as kiosk user
    # exec replaces this process - systemd keeps tracking the session
    exec su -l "$KIOSK_USER" -c "
        export DISPLAY=:0
        export XAUTHORITY='$xauth_file'
        export XDG_RUNTIME_DIR='$runtime_dir'
        export HOME='$KIOSK_HOME'
        cd '$KIOSK_HOME'
        exec '$KIOSK_HOME/.xsession'
    "
}

# ══════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════
main() {
    log "════════════════════════════════════════════════"
    log "SecuBox Kiosk Launcher v2.4 (1.6.6)"
    log "════════════════════════════════════════════════"

    check_prerequisites
    configure_x11

    local url
    url=$(determine_url)

    create_session "$url"
    start_display
}

main "$@"
