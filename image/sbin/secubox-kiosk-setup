#!/bin/bash
# ══════════════════════════════════════════════════════════════════
#  secubox-kiosk-setup — GUI Kiosk Mode Configuration
#  Installs minimal GUI with Chromium kiosk on SecuBox WebUI
#  For non-headless devices (x64 with display, touchscreen, etc.)
# ══════════════════════════════════════════════════════════════════
set -euo pipefail

KIOSK_USER="secubox-kiosk"
KIOSK_HOME="/home/${KIOSK_USER}"
KIOSK_URL="https://localhost:9443/"
MARKER="/var/lib/secubox/.kiosk-installed"
ENABLED_MARKER="/var/lib/secubox/.kiosk-enabled"

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; NC='\033[0m'
log() { echo -e "${CYAN}[kiosk]${NC} $*"; }
ok()  { echo -e "${GREEN}[  OK  ]${NC} $*"; }
err() { echo -e "${RED}[FAIL ]${NC} $*" >&2; exit 1; }

usage() {
    cat <<EOF
Usage: secubox-kiosk-setup {install|enable|disable|status}

Commands:
  install  - Install minimal GUI packages (cage, chromium)
  enable   - Enable kiosk mode autostart
  disable  - Disable kiosk mode (console only)
  status   - Show current kiosk status

The kiosk displays the SecuBox WebUI in fullscreen Chromium,
using the Cage Wayland compositor (minimal footprint).
EOF
    exit 0
}

# ── Install Minimal GUI Packages ────────────────────────────────────
install_kiosk() {
    log "Installing kiosk mode packages..."

    # Check if already installed
    if [[ -f "$MARKER" ]]; then
        log "Kiosk packages already installed"
        # Still ensure user and scripts exist
        setup_kiosk_user
        return 0
    fi

    # Required packages for Wayland kiosk
    # cage: minimal Wayland compositor
    # chromium: web browser in kiosk mode
    # fonts-dejavu: readable fonts
    # libinput: touchscreen/mouse support
    apt-get update -qq

    apt-get install -y --no-install-recommends \
        cage \
        chromium \
        fonts-dejavu-core \
        libinput10 \
        libegl1 \
        libgles2 \
        libgbm1 \
        libdrm2 \
        mesa-utils \
        xdg-utils \
        || err "Failed to install kiosk packages"

    # Setup user and scripts
    setup_kiosk_user

    # Mark as installed
    mkdir -p /var/lib/secubox
    echo "installed=$(date -Iseconds)" > "$MARKER"

    ok "Kiosk mode installed"
    log "Run 'secubox-kiosk-setup enable' to activate"
}

# ── Setup Kiosk User and Scripts ────────────────────────────────────
setup_kiosk_user() {
    # Create kiosk user with UID 1000 if not exists
    if ! id "$KIOSK_USER" &>/dev/null; then
        # Use UID 1000 to match XDG_RUNTIME_DIR in service file
        useradd -r -u 1000 -m -d "$KIOSK_HOME" -s /usr/sbin/nologin \
            -G video,audio,input,render "$KIOSK_USER" 2>/dev/null || \
        useradd -r -m -d "$KIOSK_HOME" -s /usr/sbin/nologin \
            -G video,audio,input,render "$KIOSK_USER"
        ok "Created kiosk user: $KIOSK_USER"
    fi

    # Get actual UID
    local KIOSK_UID
    KIOSK_UID=$(id -u "$KIOSK_USER")

    # Create kiosk script
    mkdir -p "${KIOSK_HOME}/.config"
    cat > "${KIOSK_HOME}/start-kiosk.sh" <<'KIOSK'
#!/bin/bash
# SecuBox Kiosk Launcher

# Wait for services to be ready
for i in {1..30}; do
    if curl -sk https://localhost:9443/ >/dev/null 2>&1; then
        break
    fi
    sleep 1
done

# Kiosk URL (local SecuBox WebUI)
URL="${KIOSK_URL:-https://localhost:9443/}"

# Chromium flags for kiosk mode
CHROMIUM_FLAGS=(
    --kiosk
    --no-first-run
    --disable-translate
    --disable-infobars
    --disable-session-crashed-bubble
    --disable-restore-background-contents
    --disable-sync
    --disable-features=TranslateUI
    --ignore-certificate-errors
    --noerrdialogs
    --enable-features=OverlayScrollbar
    --start-fullscreen
    --window-position=0,0
    --check-for-update-interval=604800
    --disable-component-update
    --disable-default-apps
    --disable-extensions
    --disable-background-networking
    --disable-domain-reliability
    --disable-client-side-phishing-detection
    "$URL"
)

exec chromium "${CHROMIUM_FLAGS[@]}"
KIOSK
    chmod +x "${KIOSK_HOME}/start-kiosk.sh"
    chown -R "$KIOSK_USER":"$KIOSK_USER" "$KIOSK_HOME"

    # Update systemd service with correct UID (only if service file doesn't exist or needs update)
    update_service_file "$KIOSK_UID"
}

# ── Update Service File with Correct UID ─────────────────────────
update_service_file() {
    local KIOSK_UID="${1:-1000}"

    cat > /etc/systemd/system/secubox-kiosk.service <<EOF
[Unit]
Description=SecuBox Kiosk Mode (WebUI Display)
After=network-online.target nginx.service secubox-hub.service
Wants=network-online.target

# Only start if kiosk is enabled
ConditionPathExists=${ENABLED_MARKER}

[Service]
Type=simple
User=${KIOSK_USER}
Group=${KIOSK_USER}

# Wayland/DRM access
SupplementaryGroups=video audio input render

# Environment for Wayland (use actual UID)
Environment=XDG_RUNTIME_DIR=/run/user/${KIOSK_UID}
Environment=WLR_LIBINPUT_NO_DEVICES=1
Environment=KIOSK_URL=${KIOSK_URL}

# Create runtime directory
ExecStartPre=/bin/mkdir -p /run/user/${KIOSK_UID}
ExecStartPre=/bin/chown ${KIOSK_USER}:${KIOSK_USER} /run/user/${KIOSK_UID}

# Cage compositor running kiosk script
ExecStart=/usr/bin/cage -s -- ${KIOSK_HOME}/start-kiosk.sh

Restart=always
RestartSec=5

[Install]
WantedBy=graphical.target
EOF

    systemctl daemon-reload
    log "Updated service file with UID ${KIOSK_UID}"
}

# ── Enable Kiosk Mode ─────────────────────────────────────────────
enable_kiosk() {
    # Check if packages are installed (cage, chromium)
    if ! command -v cage >/dev/null 2>&1; then
        log "Kiosk packages not installed, installing..."
        install_kiosk
    fi

    # Ensure user exists and scripts are in place
    setup_kiosk_user

    log "Enabling kiosk mode..."

    # Create enabled marker
    mkdir -p /var/lib/secubox
    touch "${ENABLED_MARKER}"

    # Disable console autologin if enabled
    systemctl disable getty@tty1.service 2>/dev/null || true

    # Enable graphical target
    systemctl set-default graphical.target

    # Enable kiosk service
    systemctl enable secubox-kiosk.service

    # Start kiosk
    systemctl start secubox-kiosk.service || log "Kiosk will start on next boot"

    ok "Kiosk mode enabled"
    log "SecuBox WebUI will display on the connected screen"
}

# ── Disable Kiosk Mode ────────────────────────────────────────────
disable_kiosk() {
    log "Disabling kiosk mode..."

    # Remove enabled marker
    rm -f "${ENABLED_MARKER}"

    # Stop and disable kiosk service
    systemctl stop secubox-kiosk.service 2>/dev/null || true
    systemctl disable secubox-kiosk.service 2>/dev/null || true

    # Return to multi-user (console) target
    systemctl set-default multi-user.target

    # Re-enable console login
    systemctl enable getty@tty1.service 2>/dev/null || true

    ok "Kiosk mode disabled"
    log "System will boot to console"
}

# ── Show Status ──────────────────────────────────────────────────
show_status() {
    echo ""
    echo "SecuBox Kiosk Mode Status"
    echo "========================="

    if [[ -f "$MARKER" ]]; then
        echo "Installed: yes ($(cat $MARKER))"
    else
        echo "Installed: no"
    fi

    if [[ -f "$ENABLED_MARKER" ]]; then
        echo "Enabled: yes"
    else
        echo "Enabled: no"
    fi

    local kiosk_active="inactive"
    if systemctl is-active secubox-kiosk.service &>/dev/null; then
        kiosk_active="active"
    fi
    echo "Service: $kiosk_active"

    local default_target
    default_target=$(systemctl get-default)
    echo "Default target: $default_target"

    if [[ "$default_target" == "graphical.target" ]] && [[ "$kiosk_active" == "active" ]]; then
        echo "Mode: KIOSK (GUI)"
    else
        echo "Mode: CONSOLE"
    fi

    # Check kiosk user
    if id "$KIOSK_USER" &>/dev/null; then
        local uid
        uid=$(id -u "$KIOSK_USER")
        echo "User: $KIOSK_USER (UID $uid)"
    else
        echo "User: not created"
    fi

    # Check required packages
    local pkgs_ok="yes"
    for pkg in cage chromium; do
        if ! command -v "$pkg" >/dev/null 2>&1; then
            pkgs_ok="no (missing $pkg)"
            break
        fi
    done
    echo "Packages: $pkgs_ok"

    echo ""
}

# ── Main ────────────────────────────────────────────────────────
case "${1:-}" in
    install)
        install_kiosk
        ;;
    enable)
        enable_kiosk
        ;;
    disable)
        disable_kiosk
        ;;
    status)
        show_status
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        ;;
esac
