#!/bin/bash
# ══════════════════════════════════════════════════════════════════
#  secubox-x11-splash — Loading splash with progress bar
#  Shows boot stages using zenity progress or feh fallback
# ══════════════════════════════════════════════════════════════════

LOG_TAG="secubox-splash"
log() { logger -t "$LOG_TAG" "$*" 2>/dev/null || true; }

# Main splash with zenity progress bar
show_zenity_progress() {
    log "Starting zenity progress splash"

    (
        echo "10"
        echo "# ⚡ X11 Display Server... OK"
        sleep 1

        echo "25"
        echo "# 🌐 Checking network interface..."
        sleep 1

        # Check network
        if ip addr show 2>/dev/null | grep -q "inet.*192"; then
            echo "40"
            echo "# ✅ Network ready"
        else
            echo "40"
            echo "# ⏳ Network initializing..."
        fi
        sleep 1

        echo "55"
        echo "# 🔒 Checking SecuBox services..."
        sleep 1

        # Check nginx
        echo "70"
        if systemctl is-active nginx &>/dev/null; then
            echo "# ✅ nginx running"
        else
            echo "# ⏳ Waiting for nginx..."
            # Wait up to 10s for nginx
            for i in {1..10}; do
                systemctl is-active nginx &>/dev/null && break
                sleep 1
            done
        fi

        echo "85"
        echo "# 🚀 Preparing Chromium kiosk..."
        sleep 1

        echo "100"
        echo "# ✨ SecuBox Ready!"
        sleep 0.5

    ) | zenity --progress \
        --title="SecuBox Kiosk" \
        --text="Initializing SecuBox..." \
        --percentage=0 \
        --auto-close \
        --no-cancel \
        --width=400 \
        --height=150 \
        2>/dev/null

    log "Zenity progress complete"
}

# Fallback: feh with splash image
show_feh_splash() {
    local splash_img="/usr/share/secubox/splash/boot.png"

    if [[ -f "$splash_img" ]]; then
        log "Showing feh splash: $splash_img"
        feh --fullscreen --hide-pointer "$splash_img" &
        local pid=$!

        # Wait for nginx (max 15s)
        for i in {1..15}; do
            systemctl is-active nginx &>/dev/null && break
            sleep 1
        done

        kill $pid 2>/dev/null
    fi
}

# Fallback: xmessage text splash
show_xmessage_splash() {
    log "Using xmessage fallback"

    xmessage -center -buttons "" -timeout 10 "
╔═══════════════════════════════════════╗
║                                       ║
║        ⚡ SecuBox Kiosk ⚡            ║
║                                       ║
║      Initializing services...         ║
║                                       ║
║      Please wait...                   ║
║                                       ║
╚═══════════════════════════════════════╝
" &
    local pid=$!

    # Wait for nginx
    for i in {1..15}; do
        systemctl is-active nginx &>/dev/null && break
        sleep 1
    done

    kill $pid 2>/dev/null
}

# Color gradient fallback (no deps)
show_color_progress() {
    log "Using color gradient fallback"

    local colors=("#001100" "#002200" "#003300" "#004400" "#005500" "#006600" "#007700" "#008800")

    for color in "${colors[@]}"; do
        xsetroot -solid "$color" 2>/dev/null
        systemctl is-active nginx &>/dev/null && break
        sleep 1
    done

    # Final color
    xsetroot -solid "#00AA00" 2>/dev/null
}

# Main
main() {
    log "X11 Splash starting (DISPLAY=$DISPLAY)"

    # Try zenity first (best UX)
    if command -v zenity &>/dev/null; then
        show_zenity_progress
    # Try feh with image
    elif command -v feh &>/dev/null; then
        show_feh_splash
    # Try xmessage
    elif command -v xmessage &>/dev/null; then
        show_xmessage_splash
    # Ultimate fallback: color changes
    else
        show_color_progress
    fi

    log "X11 Splash complete"
}

main "$@"
