#!/bin/bash
set -e

case "$1" in
    configure)
        # Install textual via pip (Debian bookworm version is too old)
        if ! python3 -c "import textual; from textual import __version__; exit(0 if tuple(map(int, __version__.split('.')[:2])) >= (0,40) else 1)" 2>/dev/null; then
            echo "Installing textual via pip (required >= 0.40.0)..."
            pip3 install --break-system-packages textual 2>/dev/null || \
                echo "Warning: textual pip install failed - console TUI may not work"
        fi

        # Create secubox user if it doesn't exist
        if ! id -u secubox >/dev/null 2>&1; then
            useradd -r -s /usr/sbin/nologin -d /var/lib/secubox secubox 2>/dev/null || true
        fi

        # Add secubox to required groups for terminal access
        usermod -a -G tty,dialout secubox 2>/dev/null || true

        # Ensure data directory exists
        mkdir -p /var/lib/secubox
        chown secubox:secubox /var/lib/secubox

        # Reload systemd
        systemctl daemon-reload || true

        echo "SecuBox Console TUI installed."
        echo "To enable console mode on TTY1:"
        echo "  secubox-kiosk-setup console"
        echo ""
        echo "To run manually:"
        echo "  secubox-console"
        ;;
esac

#DEBHELPER#

exit 0
