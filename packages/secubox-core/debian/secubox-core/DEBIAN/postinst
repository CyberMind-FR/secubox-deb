#!/bin/bash
set -e

case "$1" in
  configure)
    # ── Utilisateur système ──
    if ! id -u secubox >/dev/null 2>&1; then
      adduser --system --group --no-create-home \
        --home /var/lib/secubox --shell /usr/sbin/nologin secubox
    fi

    # ── Répertoires ──
    install -d -o secubox -g secubox -m 750 /etc/secubox
    install -d -o secubox -g secubox -m 750 /run/secubox
    install -d -o secubox -g secubox -m 750 /var/lib/secubox
    install -d -o secubox -g secubox -m 750 /usr/share/secubox/www

    # ── Config initiale si absente ──
    if [ ! -f /etc/secubox/secubox.conf ]; then
      install -o secubox -g secubox -m 640 \
        /usr/share/secubox-core/secubox.conf.example \
        /etc/secubox/secubox.conf
    fi

    # ── Nginx ──
    if [ -d /etc/nginx/sites-available ]; then
      install -m 644 /usr/share/secubox-core/nginx/secubox.conf \
        /etc/nginx/sites-available/secubox
      install -m 644 /usr/share/secubox-core/nginx/secubox-proxy.conf \
        /etc/nginx/snippets/secubox-proxy.conf

      # Activer le site
      if [ ! -e /etc/nginx/sites-enabled/secubox ]; then
        ln -s /etc/nginx/sites-available/secubox \
              /etc/nginx/sites-enabled/secubox
      fi
      rm -f /etc/nginx/sites-enabled/default

      nginx -t && systemctl reload nginx 2>/dev/null || true
    fi

    systemctl daemon-reload
    ;;
esac


# Automatically added by dh_python3
if command -v py3compile >/dev/null 2>&1; then
	py3compile -p secubox-core 
fi
if command -v pypy3compile >/dev/null 2>&1; then
	pypy3compile -p secubox-core  || true
fi

# End automatically added section
# Automatically added by dh_installsystemd/13.14.1ubuntu5
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	# The following line should be removed in trixie or trixie+1
	deb-systemd-helper unmask 'secubox-core.service' >/dev/null || true

	# was-enabled defaults to true, so new installations run enable.
	if deb-systemd-helper --quiet was-enabled 'secubox-core.service'; then
		# Enables the unit on first installation, creates new
		# symlinks on upgrades if the unit file has changed.
		deb-systemd-helper enable 'secubox-core.service' >/dev/null || true
	else
		# Update the statefile to add new symlinks (if any), which need to be
		# cleaned up on purge. Also remove old symlinks.
		deb-systemd-helper update-state 'secubox-core.service' >/dev/null || true
	fi
fi
# End automatically added section
# Automatically added by dh_installsystemd/13.14.1ubuntu5
if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ] ; then
	if [ -d /run/systemd/system ]; then
		systemctl --system daemon-reload >/dev/null || true
		if [ -n "$2" ]; then
			_dh_action=restart
		else
			_dh_action=start
		fi
		deb-systemd-invoke $_dh_action 'secubox-core.service' >/dev/null || true
	fi
fi
# End automatically added section

