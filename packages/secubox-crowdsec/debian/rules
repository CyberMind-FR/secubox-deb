#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-crowdsec/usr/lib/secubox/crowdsec/
	cp -r api debian/secubox-crowdsec/usr/lib/secubox/crowdsec/
	install -d debian/secubox-crowdsec/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-crowdsec/usr/share/secubox/www/ || true
	install -d debian/secubox-crowdsec/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-crowdsec/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-crowdsec/etc/nginx/secubox.d
	[ -f nginx/crowdsec.conf ] && cp nginx/crowdsec.conf debian/secubox-crowdsec/etc/nginx/secubox.d/ || true
	# Install control scripts
	install -d debian/secubox-crowdsec/usr/sbin
	[ -d sbin ] && install -m 755 sbin/* debian/secubox-crowdsec/usr/sbin/ || true
