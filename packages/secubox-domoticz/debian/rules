#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	# Create directories
	install -d $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/www/domoticz
	install -d $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/api/domoticz
	install -d $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/menu.d
	install -d $(CURDIR)/debian/secubox-domoticz/etc/nginx/secubox.d
	install -d $(CURDIR)/debian/secubox-domoticz/var/lib/secubox/domoticz

	# Install files
	cp -r $(CURDIR)/www/domoticz/* $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/www/domoticz/
	cp -r $(CURDIR)/api/* $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/api/domoticz/
	cp $(CURDIR)/menu.d/*.json $(CURDIR)/debian/secubox-domoticz/usr/share/secubox/menu.d/
	cp $(CURDIR)/nginx/*.conf $(CURDIR)/debian/secubox-domoticz/etc/nginx/secubox.d/

override_dh_installsystemd:
	dh_installsystemd --name=secubox-domoticz
