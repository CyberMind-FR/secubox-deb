#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-droplet/usr/lib/secubox/droplet/
	cp -r api debian/secubox-droplet/usr/lib/secubox/droplet/
	install -d debian/secubox-droplet/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-droplet/usr/share/secubox/www/ || true
