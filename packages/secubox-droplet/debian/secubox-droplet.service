[Unit]
Description=SecuBox Droplet File Publisher API
After=network.target secubox-core.service
Requires=secubox-core.service

[Service]
UMask=0000
Type=simple
User=secubox
Group=secubox
WorkingDirectory=/usr/lib/secubox/droplet
ExecStart=/usr/bin/python3 -m uvicorn api.main:app \
    --uds /run/secubox/droplet.sock \
    --log-level warning
Restart=on-failure
RestartSec=5

NoNewPrivileges=true
RuntimeDirectory=secubox
RuntimeDirectoryMode=0775

ReadWritePaths=/run/secubox /var/lib/secubox /etc/secubox /srv/droplet

[Install]
WantedBy=multi-user.target
