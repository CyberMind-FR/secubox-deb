#!/bin/bash
set -e
case "$1" in
  remove|upgrade|deconfigure)
    systemctl stop secubox-streamlit.service || true
    systemctl disable secubox-streamlit.service || true
    ;;
esac
# Automatically added by dh_installsystemd/13.14.1ubuntu5
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	deb-systemd-invoke stop 'secubox-streamlit.service' >/dev/null || true
fi
# End automatically added section

