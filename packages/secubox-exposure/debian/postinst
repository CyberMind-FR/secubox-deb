#!/bin/sh
set -e

case "$1" in
    configure)
        # Create config directory
        mkdir -p /etc/secubox

        # Create run directory
        mkdir -p /run/secubox

        # Enable and start service
        systemctl daemon-reload
        systemctl enable secubox-exposure.service
        systemctl start secubox-exposure.service || true
        ;;
esac

#DEBHELPER#

exit 0
