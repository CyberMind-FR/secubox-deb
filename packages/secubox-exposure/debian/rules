#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-exposure/usr/lib/secubox/exposure/api
	install -m 644 api/*.py $(CURDIR)/debian/secubox-exposure/usr/lib/secubox/exposure/api/
	install -d $(CURDIR)/debian/secubox-exposure/usr/share/secubox/www/exposure
	install -m 644 www/exposure/*.html $(CURDIR)/debian/secubox-exposure/usr/share/secubox/www/exposure/
	install -d $(CURDIR)/debian/secubox-exposure/lib/systemd/system
	install -m 644 debian/secubox-exposure.service $(CURDIR)/debian/secubox-exposure/lib/systemd/system/
