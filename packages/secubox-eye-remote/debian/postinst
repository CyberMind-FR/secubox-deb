#!/bin/bash
set -e
case "$1" in
  configure)
    # Ensure secubox user exists (created by secubox-core)
    id -u secubox >/dev/null 2>&1 || \
      adduser --system --group --no-create-home \
        --home /var/lib/secubox --shell /usr/sbin/nologin secubox

    # Create data directory for device registry
    install -d -o secubox -g secubox -m 750 /var/lib/secubox/eye-remote
    install -d -o secubox -g secubox -m 750 /run/secubox

    # Enable and start service
    systemctl daemon-reload
    systemctl enable secubox-eye-remote.service
    systemctl start secubox-eye-remote.service || true

    # Ensure nginx config directory exists and reload
    install -d -m 755 /etc/nginx/secubox.d
    systemctl reload nginx 2>/dev/null || true
    ;;
esac
#DEBHELPER#
