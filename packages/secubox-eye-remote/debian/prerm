#!/bin/bash
set -e
case "$1" in
  remove|deconfigure)
    rm -f /etc/nginx/secubox.d/eye-remote.conf
    systemctl reload nginx 2>/dev/null || true
    ;;
  upgrade)
    # Don't remove nginx config on upgrade
    ;;
esac
systemctl stop    secubox-eye-remote.service 2>/dev/null || true
systemctl disable secubox-eye-remote.service 2>/dev/null || true
#DEBHELPER#
