#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	# API files
	install -d debian/secubox-gotosocial/usr/lib/secubox/gotosocial/
	cp -r api debian/secubox-gotosocial/usr/lib/secubox/gotosocial/
	# Static www files
	install -d debian/secubox-gotosocial/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-gotosocial/usr/share/secubox/www/ || true
	# Menu definitions
	install -d debian/secubox-gotosocial/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-gotosocial/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-gotosocial/etc/nginx/secubox.d
	[ -f nginx/gotosocial.conf ] && cp nginx/gotosocial.conf debian/secubox-gotosocial/etc/nginx/secubox.d/ || true
	# Systemd service
	install -d debian/secubox-gotosocial/usr/lib/systemd/system
	[ -d systemd ] && cp systemd/*.service debian/secubox-gotosocial/usr/lib/systemd/system/ || true
