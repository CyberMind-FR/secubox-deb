#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-gotosocial/usr/lib/secubox/gotosocial/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-gotosocial/usr/lib/secubox/gotosocial/api/
	touch $(CURDIR)/debian/secubox-gotosocial/usr/lib/secubox/gotosocial/api/__init__.py
	install -d $(CURDIR)/debian/secubox-gotosocial/usr/share/secubox/www/gotosocial
	install -m 644 www/gotosocial/index.html $(CURDIR)/debian/secubox-gotosocial/usr/share/secubox/www/gotosocial/
	install -d $(CURDIR)/debian/secubox-gotosocial/etc/nginx/secubox.d
	install -m 644 nginx/gotosocial.conf $(CURDIR)/debian/secubox-gotosocial/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-gotosocial/usr/share/secubox/menu.d
	install -m 644 menu.d/810-gotosocial.json $(CURDIR)/debian/secubox-gotosocial/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-gotosocial/usr/lib/systemd/system
	install -m 644 debian/secubox-gotosocial.service $(CURDIR)/debian/secubox-gotosocial/usr/lib/systemd/system/
