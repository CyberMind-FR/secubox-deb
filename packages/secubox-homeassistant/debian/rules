#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/www/homeassistant
	install -d $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/api/homeassistant
	install -d $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/menu.d
	install -d $(CURDIR)/debian/secubox-homeassistant/etc/nginx/secubox.d
	install -d $(CURDIR)/debian/secubox-homeassistant/srv/homeassistant/config

	cp -r $(CURDIR)/www/homeassistant/* $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/www/homeassistant/
	cp -r $(CURDIR)/api/* $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/api/homeassistant/
	cp $(CURDIR)/menu.d/*.json $(CURDIR)/debian/secubox-homeassistant/usr/share/secubox/menu.d/
	cp $(CURDIR)/nginx/*.conf $(CURDIR)/debian/secubox-homeassistant/etc/nginx/secubox.d/

override_dh_installsystemd:
	dh_installsystemd --name=secubox-homeassistant
