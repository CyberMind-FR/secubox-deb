#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	# API files (to /usr/share/secubox/homeassistant for service WorkingDirectory)
	install -d debian/secubox-homeassistant/usr/share/secubox/homeassistant/
	cp -r api debian/secubox-homeassistant/usr/share/secubox/homeassistant/
	# Static www files
	install -d debian/secubox-homeassistant/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-homeassistant/usr/share/secubox/www/ || true
	# Menu definitions
	install -d debian/secubox-homeassistant/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-homeassistant/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-homeassistant/etc/nginx/secubox.d
	[ -f nginx/homeassistant.conf ] && cp nginx/homeassistant.conf debian/secubox-homeassistant/etc/nginx/secubox.d/ || true
	# Systemd service
	install -d debian/secubox-homeassistant/usr/lib/systemd/system
	cp systemd/secubox-homeassistant.service debian/secubox-homeassistant/usr/lib/systemd/system/

override_dh_installsystemd:
	# Skip dh_installsystemd since we handle it manually
	true
