#!/bin/bash
set -e
case "$1" in
  remove|deconfigure)
    rm -f /etc/nginx/secubox.d/hub.conf
    systemctl reload nginx 2>/dev/null || true
    ;;
  upgrade)
    # Don't remove nginx config on upgrade, postinst will reinstall it
    ;;
esac
systemctl stop    secubox-hub.service 2>/dev/null || true
systemctl disable secubox-hub.service 2>/dev/null || true
#DEBHELPER#
