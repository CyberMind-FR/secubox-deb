#!/bin/bash
# SecuBox Mail Server LXC Controller
# Postfix + Dovecot in Debian LXC

VERSION="2.3.0"
CONFIG_FILE="/etc/secubox/mail.toml"
CONTAINER="mailserver"
LXC_BASE="/srv/lxc"
LXC_PATH="$LXC_BASE/mailserver"
DATA_PATH="/srv/mail"
ACME_DIR="/etc/acme"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log() { echo -e "${GREEN}[MAILSERVER]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

config_get() {
    local key="$1" default="$2"
    [ -f "$CONFIG_FILE" ] && grep "^${key} *=" "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d ' "' || echo "$default"
}

DOMAIN=$(config_get "domain" "secubox.local")
HOSTNAME=$(config_get "hostname" "mail")

require_root() {
    [ "$(id -u)" -eq 0 ] || { error "Root required"; exit 1; }
}

lxc_running() { lxc-info -n "$CONTAINER" -P "$LXC_BASE" 2>/dev/null | grep -q "State:.*RUNNING"; }
lxc_exists() { [ -d "$LXC_PATH/rootfs" ]; }

# ============================================================================
# LXC Configuration
# ============================================================================

create_lxc_config() {
    mkdir -p "$LXC_PATH"
    cat > "$LXC_PATH/config" << EOF
lxc.uts.name = mailserver
lxc.rootfs.path = dir:${LXC_PATH}/rootfs
lxc.net.0.type = none
lxc.mount.auto = proc:mixed sys:ro cgroup:mixed
lxc.cap.drop = sys_module mac_admin mac_override sys_time
lxc.tty.max = 4
lxc.pty.max = 256
lxc.cgroup2.memory.max = 512M
lxc.init.cmd = /opt/start-mail.sh

# Bind mounts for persistent data
lxc.mount.entry = ${DATA_PATH}/mail var/mail none bind,create=dir 0 0
lxc.mount.entry = ${DATA_PATH}/ssl etc/ssl/mail none bind,create=dir 0 0
EOF
}

create_startup_script() {
    mkdir -p "$LXC_PATH/rootfs/opt"
    cat > "$LXC_PATH/rootfs/opt/start-mail.sh" << 'EOF'
#!/bin/bash
# Mailserver startup (Debian)

# Fix permissions
mkdir -p /run/dovecot /run/dovecot/login /var/spool/postfix/private /run/opendkim
chown -R dovecot:dovecot /run/dovecot
chown opendkim:opendkim /run/opendkim 2>/dev/null || true

# Ensure users file readable
[ -f /etc/dovecot/users ] && chmod 644 /etc/dovecot/users

# Start rsyslog for logging
service rsyslog start 2>/dev/null || true

# Start OpenDKIM (if installed)
if [ -x /usr/sbin/opendkim ] && [ -f /etc/opendkim.conf ]; then
    chown -R opendkim:opendkim /etc/opendkim 2>/dev/null || true
    /usr/sbin/opendkim -x /etc/opendkim.conf 2>/dev/null && echo "OpenDKIM started" || true
fi

# Start Postfix
service postfix start

# Start Dovecot
service dovecot start

echo "Mail services started: Postfix + Dovecot + OpenDKIM"
exec tail -f /var/log/mail.log 2>/dev/null || exec sleep infinity
EOF
    chmod +x "$LXC_PATH/rootfs/opt/start-mail.sh"
}

# ============================================================================
# Debian Bootstrap
# ============================================================================

bootstrap_debian() {
    require_root
    log "Bootstrapping Debian bookworm..."

    mkdir -p "$LXC_PATH"

    if ! command -v debootstrap &>/dev/null; then
        error "debootstrap not installed. Run: apt install debootstrap"
        exit 1
    fi

    log "Running debootstrap (this takes a few minutes)..."
    debootstrap --variant=minbase bookworm "$LXC_PATH/rootfs" http://deb.debian.org/debian

    # Configure basic system
    echo "mailserver" > "$LXC_PATH/rootfs/etc/hostname"

    cat > "$LXC_PATH/rootfs/etc/resolv.conf" << 'EOF'
nameserver 8.8.8.8
nameserver 1.1.1.1
EOF

    log "Debian base system installed"
}

install_mail_packages() {
    require_root
    local rootfs="$LXC_PATH/rootfs"

    log "Installing mail packages..."

    # Install via chroot
    chroot "$rootfs" /bin/bash << 'CHROOT_EOF'
export DEBIAN_FRONTEND=noninteractive

# Update and install packages
apt-get update
apt-get install -y --no-install-recommends \
    postfix postfix-lmdb \
    dovecot-core dovecot-imapd dovecot-pop3d dovecot-lmtpd \
    rsyslog ca-certificates openssl

# Create vmail user
groupadd -g 5000 vmail 2>/dev/null || true
useradd -u 5000 -g vmail -s /usr/sbin/nologin -d /var/mail -M vmail 2>/dev/null || true

# Clean up
apt-get clean
rm -rf /var/lib/apt/lists/*
CHROOT_EOF

    log "Packages installed"
}

# ============================================================================
# Mail Configuration
# ============================================================================

configure_postfix() {
    local rootfs="$LXC_PATH/rootfs"
    log "Configuring Postfix..."

    mkdir -p "$rootfs/etc/postfix"

    cat > "$rootfs/etc/postfix/main.cf" << EOF
# SecuBox Postfix Configuration
myhostname = ${HOSTNAME}.${DOMAIN}
mydomain = ${DOMAIN}
myorigin = \$mydomain
mydestination = \$myhostname, localhost.\$mydomain, localhost
mynetworks = 127.0.0.0/8 [::1]/128 192.168.0.0/16 10.0.0.0/8

# Virtual mailbox
virtual_mailbox_domains = ${DOMAIN}
virtual_mailbox_base = /var/mail
virtual_mailbox_maps = lmdb:/etc/postfix/vmailbox
virtual_alias_maps = lmdb:/etc/postfix/virtual
virtual_uid_maps = static:5000
virtual_gid_maps = static:5000
virtual_transport = lmtp:unix:private/dovecot-lmtp

# SASL auth via Dovecot
smtpd_sasl_auth_enable = yes
smtpd_sasl_type = dovecot
smtpd_sasl_path = private/auth
smtpd_sasl_security_options = noanonymous
broken_sasl_auth_clients = yes

# TLS
smtpd_tls_cert_file = /etc/ssl/mail/fullchain.pem
smtpd_tls_key_file = /etc/ssl/mail/privkey.pem
smtpd_tls_security_level = may
smtp_tls_security_level = may

# Restrictions
smtpd_recipient_restrictions = permit_sasl_authenticated, permit_mynetworks, reject_unauth_destination
smtpd_sender_restrictions = permit_sasl_authenticated, permit_mynetworks

# Limits
mailbox_size_limit = 0
message_size_limit = 52428800
inet_interfaces = all
inet_protocols = ipv4
EOF

    cat > "$rootfs/etc/postfix/master.cf" << 'EOF'
smtp      inet  n       -       y       -       -       smtpd
submission inet n       -       y       -       -       smtpd
  -o syslog_name=postfix/submission
  -o smtpd_tls_security_level=encrypt
  -o smtpd_sasl_auth_enable=yes
  -o smtpd_recipient_restrictions=permit_sasl_authenticated,reject
smtps     inet  n       -       y       -       -       smtpd
  -o syslog_name=postfix/smtps
  -o smtpd_tls_wrappermode=yes
  -o smtpd_sasl_auth_enable=yes
  -o smtpd_recipient_restrictions=permit_sasl_authenticated,reject
pickup    unix  n       -       y       60      1       pickup
cleanup   unix  n       -       y       -       0       cleanup
qmgr      unix  n       -       n       300     1       qmgr
tlsmgr    unix  -       -       y       1000?   1       tlsmgr
rewrite   unix  -       -       y       -       -       trivial-rewrite
bounce    unix  -       -       y       -       0       bounce
defer     unix  -       -       y       -       0       bounce
trace     unix  -       -       y       -       0       bounce
verify    unix  -       -       y       -       1       verify
flush     unix  n       -       y       1000?   0       flush
proxymap  unix  -       -       n       -       -       proxymap
smtp      unix  -       -       y       -       -       smtp
relay     unix  -       -       y       -       -       smtp
showq     unix  n       -       y       -       -       showq
error     unix  -       -       y       -       -       error
retry     unix  -       -       y       -       -       error
discard   unix  -       -       y       -       -       discard
local     unix  -       n       n       -       -       local
virtual   unix  -       n       n       -       -       virtual
lmtp      unix  -       -       y       -       -       lmtp
anvil     unix  -       -       y       -       1       anvil
scache    unix  -       -       y       -       1       scache
EOF

    # Create empty maps
    touch "$rootfs/etc/postfix/vmailbox"
    touch "$rootfs/etc/postfix/virtual"

    log "Postfix configured"
}

configure_dovecot() {
    local rootfs="$LXC_PATH/rootfs"
    log "Configuring Dovecot..."

    mkdir -p "$rootfs/etc/dovecot"

    cat > "$rootfs/etc/dovecot/dovecot.conf" << 'EOF'
protocols = imap pop3 lmtp
listen = *
mail_location = maildir:/var/mail/%d/%n
mail_uid = 5000
mail_gid = 5000
first_valid_uid = 500
last_valid_uid = 65534

# Auth
auth_mechanisms = plain login
passdb {
  driver = passwd-file
  args = /etc/dovecot/users
}
userdb {
  driver = static
  args = uid=5000 gid=5000 home=/var/mail/%d/%n
}

# SSL disabled by default (use reverse proxy for TLS)
ssl = no

# Services
service imap-login {
  inet_listener imap {
    port = 143
  }
  inet_listener imaps {
    port = 993
    ssl = yes
  }
}

service pop3-login {
  inet_listener pop3 {
    port = 110
  }
  inet_listener pop3s {
    port = 995
    ssl = yes
  }
}

service lmtp {
  unix_listener /var/spool/postfix/private/dovecot-lmtp {
    mode = 0600
    user = postfix
    group = postfix
  }
}

service auth {
  unix_listener /var/spool/postfix/private/auth {
    mode = 0660
    user = postfix
    group = postfix
  }
}

namespace inbox {
  inbox = yes
  separator = /
}

log_path = /var/log/dovecot.log
info_log_path = /var/log/dovecot.log
EOF

    # Create empty users file
    touch "$rootfs/etc/dovecot/users"
    chmod 644 "$rootfs/etc/dovecot/users"

    log "Dovecot configured"
}

generate_ssl_cert() {
    log "Generating self-signed SSL certificate..."

    mkdir -p "$DATA_PATH/ssl"

    openssl req -x509 -nodes -days 3650 \
        -newkey rsa:2048 \
        -keyout "$DATA_PATH/ssl/privkey.pem" \
        -out "$DATA_PATH/ssl/fullchain.pem" \
        -subj "/CN=${HOSTNAME}.${DOMAIN}/O=SecuBox/C=FR" 2>/dev/null

    chmod 600 "$DATA_PATH/ssl/"*.pem
    log "SSL certificate generated"
}

# ============================================================================
# ACME Certificate Management (Let's Encrypt)
# ============================================================================

acme_available() {
    command -v acme.sh >/dev/null 2>&1
}

cmd_acme_issue() {
    require_root
    local email="${1:-admin@${DOMAIN}}"

    if ! acme_available; then
        error "acme.sh not installed"
        echo "Install with: curl https://get.acme.sh | sh"
        return 1
    fi

    local fqdn="${HOSTNAME}.${DOMAIN}"

    log "Requesting certificate for $fqdn..."

    # Stop container temporarily for standalone mode
    local was_running=false
    if lxc_running; then
        was_running=true
        log "Stopping container for certificate issuance..."
        cmd_stop
        sleep 2
    fi

    # Request certificate with all mail-related names
    local domains="-d $fqdn"
    [ "$HOSTNAME" != "mail" ] && domains="$domains -d mail.${DOMAIN}"
    domains="$domains -d smtp.${DOMAIN} -d imap.${DOMAIN} -d pop3.${DOMAIN}"

    if acme.sh --issue $domains --standalone --accountemail "$email" --force; then
        log "Certificate issued successfully!"

        # Install certificate to data directory
        cmd_acme_install

        # Restart container
        [ "$was_running" = "true" ] && cmd_start
        return 0
    else
        error "Certificate request failed"
        [ "$was_running" = "true" ] && cmd_start
        return 1
    fi
}

cmd_acme_install() {
    require_root

    if ! acme_available; then
        error "acme.sh not installed"
        return 1
    fi

    local fqdn="${HOSTNAME}.${DOMAIN}"
    local acme_cert_dir="$ACME_DIR/${fqdn}"

    if [ ! -d "$acme_cert_dir" ] && [ ! -d "${HOME}/.acme.sh/${fqdn}" ]; then
        error "No ACME certificate found for $fqdn"
        return 1
    fi

    # Find certificate location
    local cert_src="${acme_cert_dir}/fullchain.cer"
    local key_src="${acme_cert_dir}/${fqdn}.key"

    if [ ! -f "$cert_src" ]; then
        cert_src="${HOME}/.acme.sh/${fqdn}/fullchain.cer"
        key_src="${HOME}/.acme.sh/${fqdn}/${fqdn}.key"
    fi

    if [ ! -f "$cert_src" ]; then
        error "Certificate files not found"
        return 1
    fi

    log "Installing certificate..."
    mkdir -p "$DATA_PATH/ssl"
    cp "$cert_src" "$DATA_PATH/ssl/fullchain.pem"
    cp "$key_src" "$DATA_PATH/ssl/privkey.pem"
    chmod 600 "$DATA_PATH/ssl/"*.pem

    # Sync to container
    cmd_sync_ssl

    log "Certificate installed"
}

cmd_acme_renew() {
    require_root

    if ! acme_available; then
        error "acme.sh not installed"
        return 1
    fi

    local fqdn="${HOSTNAME}.${DOMAIN}"

    log "Renewing certificate for $fqdn..."

    if acme.sh --renew -d "$fqdn" --force; then
        log "Certificate renewed"
        cmd_acme_install
    else
        warn "Certificate renewal failed or not yet due"
    fi
}

cmd_sync_ssl() {
    log "Syncing SSL certificates to container..."

    if [ ! -d "$LXC_PATH/rootfs" ]; then
        error "Container not installed"
        return 1
    fi

    mkdir -p "$LXC_PATH/rootfs/etc/ssl/mail"
    cp "$DATA_PATH/ssl/"*.pem "$LXC_PATH/rootfs/etc/ssl/mail/" 2>/dev/null || true
    chmod 600 "$LXC_PATH/rootfs/etc/ssl/mail/"*.pem 2>/dev/null || true

    # Enable SSL in Dovecot if we have certs
    if [ -f "$DATA_PATH/ssl/fullchain.pem" ]; then
        enable_dovecot_ssl
    fi

    # Reload services if running
    if lxc_running; then
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- postfix reload 2>/dev/null || true
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- doveadm reload 2>/dev/null || true
    fi

    log "SSL certificates synced"
}

enable_dovecot_ssl() {
    local rootfs="$LXC_PATH/rootfs"
    [ ! -d "$rootfs/etc/dovecot" ] && return

    log "Enabling Dovecot SSL..."

    # Update dovecot config to enable SSL
    cat > "$rootfs/etc/dovecot/conf.d/10-ssl.conf" << 'EOF'
# SecuBox SSL Configuration
ssl = yes
ssl_cert = </etc/ssl/mail/fullchain.pem
ssl_key = </etc/ssl/mail/privkey.pem
ssl_min_protocol = TLSv1.2
ssl_cipher_list = ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384
ssl_prefer_server_ciphers = yes
EOF

    log "Dovecot SSL enabled"
}

cmd_ssl_status() {
    echo ""
    echo "SSL Certificate Status"
    echo "======================"
    echo ""

    local cert_file="$DATA_PATH/ssl/fullchain.pem"

    if [ ! -f "$cert_file" ]; then
        echo -e "Certificate: ${RED}Not installed${NC}"
        echo ""
        echo "Options:"
        echo "  1. Generate self-signed: mailserverctl ssl selfsigned"
        echo "  2. Request ACME cert:    mailserverctl acme issue [email]"
        return 0
    fi

    echo -e "Certificate: ${GREEN}Installed${NC}"
    echo ""

    # Show certificate info
    openssl x509 -in "$cert_file" -noout -subject -dates -issuer 2>/dev/null | while read line; do
        echo "  $line"
    done

    # Check if ACME managed
    local fqdn="${HOSTNAME}.${DOMAIN}"
    if [ -d "$ACME_DIR/${fqdn}" ] || [ -d "${HOME}/.acme.sh/${fqdn}" ]; then
        echo ""
        echo -e "Type: ${GREEN}ACME (Let's Encrypt)${NC}"
        echo "Auto-renewal: Enabled via acme.sh cron"
    else
        echo ""
        echo -e "Type: ${YELLOW}Self-signed${NC}"
    fi

    # Check expiration
    local expires=$(openssl x509 -in "$cert_file" -noout -enddate 2>/dev/null | cut -d= -f2)
    local expires_epoch=$(date -d "$expires" +%s 2>/dev/null || echo 0)
    local now_epoch=$(date +%s)
    local days_left=$(( (expires_epoch - now_epoch) / 86400 ))

    echo ""
    if [ "$days_left" -lt 0 ]; then
        echo -e "Status: ${RED}EXPIRED${NC}"
    elif [ "$days_left" -lt 30 ]; then
        echo -e "Status: ${YELLOW}Expires in $days_left days${NC}"
    else
        echo -e "Status: ${GREEN}Valid ($days_left days remaining)${NC}"
    fi
    echo ""
}

# ============================================================================
# Commands
# ============================================================================

cmd_install() {
    require_root
    log "Installing Mail Server LXC (Debian bookworm)..."

    # Create data directories
    mkdir -p "$DATA_PATH"/{mail,config,ssl,dkim,backups}
    touch "$DATA_PATH/config/users"
    touch "$DATA_PATH/config/vmailbox"
    touch "$DATA_PATH/config/virtual"
    chmod 644 "$DATA_PATH/config/users"

    if ! lxc_exists; then
        bootstrap_debian
    fi

    install_mail_packages
    configure_postfix
    configure_dovecot
    create_lxc_config
    create_startup_script

    # Generate self-signed cert if none exists
    [ ! -f "$DATA_PATH/ssl/fullchain.pem" ] && generate_ssl_cert

    # Create directories in container
    mkdir -p "$LXC_PATH/rootfs/var/mail"
    mkdir -p "$LXC_PATH/rootfs/var/spool/postfix/private"
    mkdir -p "$LXC_PATH/rootfs/etc/ssl/mail"
    mkdir -p "$LXC_PATH/rootfs/etc/dovecot"
    mkdir -p "$LXC_PATH/rootfs/etc/postfix"

    # Copy initial config files
    cp "$DATA_PATH/config/users" "$LXC_PATH/rootfs/etc/dovecot/users"
    cp "$DATA_PATH/config/vmailbox" "$LXC_PATH/rootfs/etc/postfix/vmailbox"
    cp "$DATA_PATH/config/virtual" "$LXC_PATH/rootfs/etc/postfix/virtual"
    cp "$DATA_PATH/ssl/"*.pem "$LXC_PATH/rootfs/etc/ssl/mail/" 2>/dev/null || true

    log "Mail Server installed!"
    log "Start with: mailserverctl start"
    log "Add users with: mailctl user add user@$DOMAIN"
}

cmd_start() {
    require_root

    if lxc_running; then
        log "Mail server already running"
        return 0
    fi

    if ! lxc_exists; then
        error "Mail server not installed. Run 'mailserverctl install' first"
        return 1
    fi

    create_lxc_config

    log "Starting Mail Server..."
    lxc-start -n "$CONTAINER" -P "$LXC_BASE" -d
    sleep 5

    if lxc_running; then
        log "Mail server started"
    else
        error "Failed to start"
        return 1
    fi
}

cmd_stop() {
    require_root

    if ! lxc_running; then
        log "Mail server is not running"
        return 0
    fi

    log "Stopping Mail Server..."
    lxc-stop -n "$CONTAINER" -P "$LXC_BASE"
    log "Stopped"
}

cmd_restart() {
    cmd_stop
    sleep 2
    cmd_start
}

cmd_status() {
    echo ""
    echo "Mail Server LXC v$VERSION"
    echo "========================="
    echo ""
    echo "Container: $CONTAINER"
    echo "Base OS: Debian bookworm"

    if lxc_running; then
        echo -e "Status: ${GREEN}Running${NC}"
        echo "Domain: $DOMAIN"
        echo "Hostname: $HOSTNAME.$DOMAIN"
    elif lxc_exists; then
        echo -e "Status: ${YELLOW}Stopped${NC}"
    else
        echo -e "Status: ${RED}Not installed${NC}"
    fi
}

cmd_shell() {
    if ! lxc_running; then
        error "Container not running"
        return 1
    fi
    lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- /bin/bash
}

cmd_sync() {
    require_root
    log "Syncing configuration to container..."

    if [ ! -d "$LXC_PATH/rootfs" ]; then
        error "Container not installed"
        return 1
    fi

    # Sync user files
    cp "$DATA_PATH/config/users" "$LXC_PATH/rootfs/etc/dovecot/users"
    cp "$DATA_PATH/config/vmailbox" "$LXC_PATH/rootfs/etc/postfix/vmailbox"
    cp "$DATA_PATH/config/virtual" "$LXC_PATH/rootfs/etc/postfix/virtual"
    chmod 644 "$LXC_PATH/rootfs/etc/dovecot/users"

    # Sync SSL if exists
    cp "$DATA_PATH/ssl/"*.pem "$LXC_PATH/rootfs/etc/ssl/mail/" 2>/dev/null || true

    # Rebuild postmap if running
    if lxc_running; then
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- postmap lmdb:/etc/postfix/vmailbox 2>/dev/null || true
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- postmap lmdb:/etc/postfix/virtual 2>/dev/null || true
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- postfix reload 2>/dev/null || true
    fi

    log "Configuration synced"
}

# ============================================================================
# DKIM with OpenDKIM Integration
# ============================================================================

cmd_dkim_setup() {
    require_root
    log "Setting up DKIM signing for $DOMAIN..."

    # Generate keys
    cmd_dkim_keygen

    # Install OpenDKIM in container
    cmd_dkim_install

    # Configure OpenDKIM
    cmd_dkim_configure

    # Sync to container and reload
    cmd_dkim_sync

    log "DKIM setup complete!"
    log ""
    log "Add this TXT record to DNS:"
    cat "$DATA_PATH/dkim/default.txt"
}

cmd_dkim_keygen() {
    require_root
    log "Generating DKIM keys for $DOMAIN..."

    mkdir -p "$DATA_PATH/dkim"

    # Generate 2048-bit RSA key pair
    local selector="default"
    openssl genrsa -out "$DATA_PATH/dkim/${selector}.private" 2048 2>/dev/null
    openssl rsa -in "$DATA_PATH/dkim/${selector}.private" -pubout -out "$DATA_PATH/dkim/${selector}.pub" 2>/dev/null

    # Extract public key for DNS (remove headers and newlines)
    local pubkey=$(grep -v "^-" "$DATA_PATH/dkim/${selector}.pub" | tr -d '\n')

    # Save DNS record in split format (for long keys)
    cat > "$DATA_PATH/dkim/${selector}.txt" << EOF
${selector}._domainkey.$DOMAIN. IN TXT "v=DKIM1; k=rsa; p=$pubkey"
EOF

    # Also save in BIND format
    cat > "$DATA_PATH/dkim/${selector}.bind" << EOF
; DKIM record for $DOMAIN
; Selector: ${selector}
; Generated: $(date -Iseconds)
${selector}._domainkey IN TXT ( "v=DKIM1; k=rsa; "
  "p=$pubkey" )
EOF

    chmod 600 "$DATA_PATH/dkim/"*.private

    log "DKIM keys generated"
}

cmd_dkim_install() {
    require_root

    if ! lxc_exists; then
        error "Container not installed"
        return 1
    fi

    log "Installing OpenDKIM in container..."

    # Use lxc-attach if container is running, otherwise chroot
    if lxc_running; then
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- /bin/bash << 'EOF'
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y -o Dpkg::Options::="--force-confold" --no-install-recommends opendkim opendkim-tools
apt-get clean
rm -rf /var/lib/apt/lists/*
EOF
    else
        chroot "$LXC_PATH/rootfs" /bin/bash << 'CHROOT_EOF'
export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y -o Dpkg::Options::="--force-confold" --no-install-recommends opendkim opendkim-tools
apt-get clean
rm -rf /var/lib/apt/lists/*
CHROOT_EOF
    fi

    log "OpenDKIM installed"
}

cmd_dkim_configure() {
    require_root
    local rootfs="$LXC_PATH/rootfs"

    if [ ! -d "$rootfs" ]; then
        error "Container not installed"
        return 1
    fi

    log "Configuring OpenDKIM..."

    mkdir -p "$rootfs/etc/opendkim/keys/$DOMAIN"

    # Main OpenDKIM config
    cat > "$rootfs/etc/opendkim.conf" << EOF
# SecuBox OpenDKIM Configuration
Syslog                  yes
SyslogSuccess           yes
LogWhy                  yes

Canonicalization        relaxed/simple
Mode                    sv
SubDomains              no
AutoRestart             yes
AutoRestartRate         10/1M
Background              yes
DNSTimeout              5
SignatureAlgorithm      rsa-sha256

# Tables
KeyTable                /etc/opendkim/KeyTable
SigningTable            refile:/etc/opendkim/SigningTable
ExternalIgnoreList      /etc/opendkim/TrustedHosts
InternalHosts           /etc/opendkim/TrustedHosts

# Socket for Postfix
Socket                  inet:8891@localhost
UMask                   002
UserID                  opendkim:opendkim

PidFile                 /run/opendkim/opendkim.pid
EOF

    # Key table
    cat > "$rootfs/etc/opendkim/KeyTable" << EOF
default._domainkey.$DOMAIN $DOMAIN:default:/etc/opendkim/keys/$DOMAIN/default.private
EOF

    # Signing table
    cat > "$rootfs/etc/opendkim/SigningTable" << EOF
*@$DOMAIN default._domainkey.$DOMAIN
EOF

    # Trusted hosts
    cat > "$rootfs/etc/opendkim/TrustedHosts" << EOF
127.0.0.1
localhost
$DOMAIN
*.${DOMAIN}
EOF

    log "OpenDKIM configured"
}

cmd_dkim_sync() {
    require_root
    local rootfs="$LXC_PATH/rootfs"

    if [ ! -d "$rootfs" ]; then
        error "Container not installed"
        return 1
    fi

    log "Syncing DKIM keys to container..."

    # Copy private key
    mkdir -p "$rootfs/etc/opendkim/keys/$DOMAIN"
    cp "$DATA_PATH/dkim/default.private" "$rootfs/etc/opendkim/keys/$DOMAIN/"
    chown -R 128:130 "$rootfs/etc/opendkim/keys/$DOMAIN" 2>/dev/null || \
    chroot "$rootfs" chown -R opendkim:opendkim /etc/opendkim/keys 2>/dev/null || true
    chmod 600 "$rootfs/etc/opendkim/keys/$DOMAIN/"*.private

    # Update Postfix to use milter
    if [ -f "$rootfs/etc/postfix/main.cf" ]; then
        if ! grep -q "milter_protocol" "$rootfs/etc/postfix/main.cf"; then
            cat >> "$rootfs/etc/postfix/main.cf" << 'EOF'

# DKIM via OpenDKIM
milter_protocol = 6
milter_default_action = accept
smtpd_milters = inet:localhost:8891
non_smtpd_milters = $smtpd_milters
EOF
        fi
    fi

    # Reload services if running
    if lxc_running; then
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- mkdir -p /run/opendkim
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- chown opendkim:opendkim /run/opendkim
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- service opendkim start 2>/dev/null || true
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- postfix reload 2>/dev/null || true
    fi

    log "DKIM keys synced"
}

cmd_dkim_status() {
    echo ""
    echo "DKIM Status for $DOMAIN"
    echo "========================"
    echo ""

    # Check key files
    if [ -f "$DATA_PATH/dkim/default.private" ]; then
        echo -e "Private key: ${GREEN}Installed${NC}"
        echo "  Path: $DATA_PATH/dkim/default.private"
    else
        echo -e "Private key: ${RED}Not found${NC}"
        echo "  Run: mailserverctl dkim setup"
        return
    fi

    # Check DNS record
    echo ""
    echo "DNS Record:"
    if [ -f "$DATA_PATH/dkim/default.txt" ]; then
        cat "$DATA_PATH/dkim/default.txt"
    fi

    # Check OpenDKIM service in container
    if lxc_running; then
        echo ""
        echo "OpenDKIM service:"
        if lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- pgrep opendkim >/dev/null 2>&1; then
            echo -e "  Status: ${GREEN}Running${NC}"
        else
            echo -e "  Status: ${YELLOW}Stopped${NC}"
        fi
    fi

    # Check Postfix milter config
    if [ -f "$LXC_PATH/rootfs/etc/postfix/main.cf" ]; then
        echo ""
        echo "Postfix milter integration:"
        if grep -q "smtpd_milters.*8891" "$LXC_PATH/rootfs/etc/postfix/main.cf" 2>/dev/null; then
            echo -e "  Status: ${GREEN}Configured${NC}"
        else
            echo -e "  Status: ${YELLOW}Not configured${NC}"
        fi
    fi
    echo ""
}

cmd_dkim() {
    # For backward compatibility, default to keygen only
    cmd_dkim_keygen
    echo ""
    log "Add this TXT record to DNS:"
    cat "$DATA_PATH/dkim/default.txt"
    echo ""
    log "For full OpenDKIM integration, run: mailserverctl dkim setup"
}

cmd_logs() {
    local lines="${1:-50}"
    if ! lxc_running; then
        error "Container not running"
        return 1
    fi
    lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- tail -n "$lines" /var/log/mail.log 2>/dev/null || \
        lxc-attach -n "$CONTAINER" -P "$LXC_BASE" -- tail -n "$lines" /var/log/syslog
}

# ============================================================================
# THREE-FOLD ARCHITECTURE
# ============================================================================

cmd_components() {
    local installed=false
    local running=false
    lxc_exists && installed=true
    lxc_running && running=true

    # SSL status
    local ssl_installed=false
    local ssl_type="none"
    local ssl_expires=""
    local fqdn="${HOSTNAME}.${DOMAIN}"

    if [ -f "$DATA_PATH/ssl/fullchain.pem" ]; then
        ssl_installed=true
        ssl_expires=$(openssl x509 -in "$DATA_PATH/ssl/fullchain.pem" -noout -enddate 2>/dev/null | cut -d= -f2)
        if [ -d "$ACME_DIR/${fqdn}" ] || [ -d "${HOME}/.acme.sh/${fqdn}" ]; then
            ssl_type="acme"
        else
            ssl_type="selfsigned"
        fi
    fi

    # ACME status
    local acme_available=false
    command -v acme.sh >/dev/null 2>&1 && acme_available=true

    cat <<EOF
{
  "components": [
    {
      "name": "Mail Server",
      "type": "lxc",
      "container": "$CONTAINER",
      "description": "Postfix + Dovecot mail server",
      "os": "debian-bookworm",
      "installed": $installed,
      "running": $running
    },
    {
      "name": "Postfix",
      "type": "service",
      "description": "SMTP server (MTA)",
      "ports": [25, 465, 587],
      "parent": "$CONTAINER"
    },
    {
      "name": "Dovecot",
      "type": "service",
      "description": "IMAP/POP3 server (MDA)",
      "ports": [143, 993, 110, 995],
      "parent": "$CONTAINER"
    },
    {
      "name": "SSL/TLS Certificate",
      "type": "certificate",
      "description": "TLS encryption for mail protocols",
      "installed": $ssl_installed,
      "type_detail": "$ssl_type",
      "expires": "$ssl_expires"
    },
    {
      "name": "ACME Client",
      "type": "tool",
      "description": "Let's Encrypt certificate automation",
      "installed": $acme_available
    }
  ]
}
EOF
}

cmd_access() {
    local running=false
    lxc_running && running=true

    local ssl_enabled=false
    [ -f "$DATA_PATH/ssl/fullchain.pem" ] && ssl_enabled=true

    cat <<EOF
{
  "smtp": {
    "host": "$HOSTNAME.$DOMAIN",
    "ports": {"smtp": 25, "submission": 587, "smtps": 465},
    "tls": $ssl_enabled,
    "starttls": true
  },
  "imap": {
    "host": "$HOSTNAME.$DOMAIN",
    "ports": {"imap": 143, "imaps": 993},
    "tls": $ssl_enabled
  },
  "pop3": {
    "host": "$HOSTNAME.$DOMAIN",
    "ports": {"pop3": 110, "pop3s": 995},
    "tls": $ssl_enabled
  },
  "ssl_enabled": $ssl_enabled,
  "running": $running,
  "webmail": "https://webmail.$DOMAIN"
}
EOF
}

show_help() {
    cat << EOF
Mail Server LXC Controller v$VERSION
Debian bookworm based container
Three-fold architecture: Components, Status, Access

Usage: mailserverctl <command>

Container:
  install       Install LXC container (Debian)
  start         Start mail server
  stop          Stop mail server
  restart       Restart
  status        Show status
  shell         Open shell in container
  sync          Sync config files to container
  logs [n]      View last n lines of mail.log

SSL/TLS:
  ssl status    Show certificate status
  ssl selfsigned Generate self-signed certificate
  acme issue [email]  Request Let's Encrypt certificate
  acme renew    Renew ACME certificate
  acme install  Install ACME cert to container

DKIM:
  dkim setup    Full OpenDKIM setup (keygen + install + configure)
  dkim keygen   Generate DKIM key pair only
  dkim status   Show DKIM status
  dkim sync     Sync keys to container
  dkim          Legacy: keygen only (deprecated)

Three-fold:
  components    List system components (JSON)
  access        Show connection info (JSON)

Examples:
  mailserverctl install
  mailserverctl acme issue admin@example.com
  mailserverctl ssl status

EOF
}

case "${1:-}" in
    install)    shift; cmd_install "$@" ;;
    start)      shift; cmd_start "$@" ;;
    stop)       shift; cmd_stop "$@" ;;
    restart)    shift; cmd_restart "$@" ;;
    status)     shift; cmd_status "$@" ;;
    shell)      shift; cmd_shell "$@" ;;
    sync)       shift; cmd_sync "$@" ;;
    # DKIM commands
    dkim)
        shift
        case "${1:-}" in
            setup)   cmd_dkim_setup ;;
            keygen)  cmd_dkim_keygen ;;
            status)  cmd_dkim_status ;;
            sync)    cmd_dkim_sync ;;
            install) cmd_dkim_install ;;
            configure) cmd_dkim_configure ;;
            *)       cmd_dkim ;;  # Legacy compatibility
        esac
        ;;
    logs)       shift; cmd_logs "$@" ;;
    components) cmd_components ;;
    access)     cmd_access ;;
    # SSL/TLS commands
    ssl)
        shift
        case "${1:-status}" in
            status)    cmd_ssl_status ;;
            selfsigned) generate_ssl_cert && cmd_sync_ssl ;;
            *)         cmd_ssl_status ;;
        esac
        ;;
    # ACME commands
    acme)
        shift
        case "${1:-}" in
            issue)   shift; cmd_acme_issue "$@" ;;
            renew)   cmd_acme_renew ;;
            install) cmd_acme_install ;;
            *)       echo "Usage: mailserverctl acme issue|renew|install" ;;
        esac
        ;;
    help|--help|-h|'') show_help ;;
    *)          error "Unknown: $1"; exit 1 ;;
esac
