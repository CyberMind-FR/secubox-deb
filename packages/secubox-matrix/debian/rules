#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-matrix/usr/lib/secubox/matrix/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-matrix/usr/lib/secubox/matrix/api/
	touch $(CURDIR)/debian/secubox-matrix/usr/lib/secubox/matrix/api/__init__.py
	install -d $(CURDIR)/debian/secubox-matrix/usr/share/secubox/www/matrix
	install -m 644 www/matrix/index.html $(CURDIR)/debian/secubox-matrix/usr/share/secubox/www/matrix/
	install -d $(CURDIR)/debian/secubox-matrix/etc/nginx/secubox.d
	install -m 644 nginx/matrix.conf $(CURDIR)/debian/secubox-matrix/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-matrix/usr/share/secubox/menu.d
	install -m 644 menu.d/619-matrix.json $(CURDIR)/debian/secubox-matrix/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-matrix/usr/lib/systemd/system
	install -m 644 debian/secubox-matrix.service $(CURDIR)/debian/secubox-matrix/usr/lib/systemd/system/
