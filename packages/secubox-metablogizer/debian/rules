#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-metablogizer/usr/lib/secubox/metablogizer
	cp -r api debian/secubox-metablogizer/usr/lib/secubox/metablogizer/
	install -d debian/secubox-metablogizer/usr/share/secubox/www/metablogizer
	[ -d www/metablogizer ] && cp -r www/metablogizer/. debian/secubox-metablogizer/usr/share/secubox/www/metablogizer/ || true
	install -d debian/secubox-metablogizer/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-metablogizer/usr/share/secubox/menu.d/ || true
	install -d debian/secubox-metablogizer/usr/sbin
	[ -d sbin ] && install -m 755 sbin/* debian/secubox-metablogizer/usr/sbin/ || true
