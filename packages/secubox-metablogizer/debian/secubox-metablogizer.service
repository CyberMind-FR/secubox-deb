[Unit]
Description=SecuBox MetaBlogizer API
After=network.target secubox-core.service
Requires=secubox-core.service

[Service]
Type=simple
User=secubox
Group=secubox
WorkingDirectory=/usr/lib/secubox/metablogizer
ExecStart=/usr/bin/python3 -m uvicorn api.main:app --uds /run/secubox/metablogizer.sock --log-level warning
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
