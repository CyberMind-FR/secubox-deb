[Unit]
# Only start if explicitly enabled (backend installed)
ConditionPathExists=/etc/secubox/mmpm/enabled
Description=SecuBox MMPM API
After=network.target secubox-core.service

[Service]
Type=simple
User=root
WorkingDirectory=/usr/lib/secubox/mmpm
ExecStart=/usr/bin/python3 -m uvicorn api.main:app --uds /run/secubox/mmpm.sock --log-level warning
UMask=0117
Restart=on-failure

[Install]
WantedBy=multi-user.target
