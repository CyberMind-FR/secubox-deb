#!/bin/bash
set -e
case "$1" in
  remove|upgrade)
    systemctl stop    secubox-netdata.service 2>/dev/null || true
    systemctl disable secubox-netdata.service 2>/dev/null || true
    ;;
esac
# Automatically added by dh_installsystemd/13.14.1ubuntu5
if [ -z "${DPKG_ROOT:-}" ] && [ "$1" = remove ] && [ -d /run/systemd/system ] ; then
	deb-systemd-invoke stop 'secubox-netdata.service' >/dev/null || true
fi
# End automatically added section

