#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-netmodes/usr/lib/secubox/netmodes/
	cp -r api debian/secubox-netmodes/usr/lib/secubox/netmodes/
	install -d debian/secubox-netmodes/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-netmodes/usr/share/secubox/www/ || true
	# Templates netplan par mode
	install -d debian/secubox-netmodes/etc/secubox/netmodes
	[ -d templates ] && cp -r templates/*.yaml.j2 debian/secubox-netmodes/etc/secubox/netmodes/ || true
	install -d debian/secubox-netmodes/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-netmodes/usr/share/secubox/menu.d/ || true
