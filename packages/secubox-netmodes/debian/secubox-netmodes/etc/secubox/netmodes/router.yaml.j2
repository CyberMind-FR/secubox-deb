# SecuBox Network Mode: Router
# NAT router with DHCP server on LAN
network:
  version: 2
  renderer: networkd
  ethernets:
    {{ wan | default('eth0') }}:
      dhcp4: true
      dhcp6: false
    {{ lan | default('eth1') }}:
      addresses:
        - 192.168.100.1/24
  bridges:
    br0:
      interfaces:
        - {{ lan | default('eth1') }}
      addresses:
        - 192.168.100.1/24
      dhcp4: false
      parameters:
        stp: false
        forward-delay: 0
