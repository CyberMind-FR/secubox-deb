# SecuBox Network Mode: Sniffer Inline
# Transparent bridge with DPI (tc mirred)
network:
  version: 2
  renderer: networkd
  ethernets:
    {{ upstream | default('eth0') }}:
      dhcp4: false
    {{ downstream | default('eth1') }}:
      dhcp4: false
  bridges:
    br-sniffer:
      interfaces:
        - {{ upstream | default('eth0') }}
        - {{ downstream | default('eth1') }}
      dhcp4: true
      parameters:
        stp: false
        forward-delay: 0
