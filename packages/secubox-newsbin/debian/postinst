#!/bin/bash
set -e
case "$1" in
  configure)
    install -d -o secubox -g secubox -m 750 /var/lib/secubox/newsbin
    systemctl daemon-reload
    systemctl enable secubox-newsbin.service
    systemctl start secubox-newsbin.service || true
    systemctl reload nginx 2>/dev/null || true
    ;;
esac
#DEBHELPER#
