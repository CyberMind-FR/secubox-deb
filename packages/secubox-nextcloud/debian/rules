#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-nextcloud/usr/lib/secubox/nextcloud
	cp -r api debian/secubox-nextcloud/usr/lib/secubox/nextcloud/
	install -d debian/secubox-nextcloud/usr/share/secubox/www/nextcloud
	cp -r www/nextcloud/. debian/secubox-nextcloud/usr/share/secubox/www/nextcloud/
	install -d debian/secubox-nextcloud/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-nextcloud/usr/share/secubox/menu.d/ || true
	install -d debian/secubox-nextcloud/usr/sbin
	[ -d sbin ] && install -m 755 sbin/* debian/secubox-nextcloud/usr/sbin/ || true

	# Install nginx config
	install -d $(CURDIR)/debian/secubox-nextcloud/etc/nginx/secubox.d
	install -m 644 nginx/nextcloud.conf $(CURDIR)/debian/secubox-nextcloud/etc/nginx/secubox.d/nextcloud.conf
