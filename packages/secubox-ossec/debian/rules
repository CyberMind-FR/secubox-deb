#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-ossec/usr/lib/secubox/ossec/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-ossec/usr/lib/secubox/ossec/api/
	touch $(CURDIR)/debian/secubox-ossec/usr/lib/secubox/ossec/api/__init__.py
	install -d $(CURDIR)/debian/secubox-ossec/usr/share/secubox/www/ossec
	install -m 644 www/ossec/index.html $(CURDIR)/debian/secubox-ossec/usr/share/secubox/www/ossec/
	install -d $(CURDIR)/debian/secubox-ossec/etc/nginx/secubox.d
	install -m 644 nginx/ossec.conf $(CURDIR)/debian/secubox-ossec/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-ossec/usr/share/secubox/menu.d
	install -m 644 menu.d/952-ossec.json $(CURDIR)/debian/secubox-ossec/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-ossec/usr/lib/systemd/system
	install -m 644 debian/secubox-ossec.service $(CURDIR)/debian/secubox-ossec/usr/lib/systemd/system/
