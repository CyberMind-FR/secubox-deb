#!/bin/sh
set -e

case "$1" in
    configure)
        # Create secubox user if it doesn't exist
        if ! getent passwd secubox > /dev/null 2>&1; then
            adduser --system --group --home /var/lib/secubox --no-create-home secubox
        fi

        # Create runtime directory
        mkdir -p /run/secubox
        chown secubox:secubox /run/secubox
        chmod 755 /run/secubox

        # Create log directory
        mkdir -p /var/log/secubox
        chown secubox:secubox /var/log/secubox
        chmod 755 /var/log/secubox

        # Enable and start the service
        systemctl daemon-reload
        systemctl enable secubox-p2p.service
        systemctl start secubox-p2p.service || true

        # Reload nginx if running
        if systemctl is-active --quiet nginx; then
            systemctl reload nginx || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
