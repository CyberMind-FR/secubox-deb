#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-publish/usr/lib/secubox/publish
	cp -r api debian/secubox-publish/usr/lib/secubox/publish/
	install -d debian/secubox-publish/usr/share/secubox/www/publish
	cp -r www/publish/. debian/secubox-publish/usr/share/secubox/www/publish/
	install -d debian/secubox-publish/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-publish/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-publish/etc/nginx/secubox.d
	[ -f nginx/publish.conf ] && cp nginx/publish.conf debian/secubox-publish/etc/nginx/secubox.d/ || true
