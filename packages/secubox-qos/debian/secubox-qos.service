[Unit]
Description=SecuBox QoS / Bandwidth Manager API
After=network.target secubox-core.service
Requires=secubox-core.service

[Service]
UMask=0000
Type=simple
User=root
Group=root
WorkingDirectory=/usr/lib/secubox/qos
ExecStart=/usr/bin/python3 -m uvicorn api.main:app \
    --uds /run/secubox/qos.sock \
    --log-level warning
Restart=on-failure
RestartSec=5
PrivateTmp=true

[Install]
WantedBy=multi-user.target
