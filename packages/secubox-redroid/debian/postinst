#!/bin/bash
set -e
case "$1" in
  configure)
    install -d -o secubox -g secubox -m 750 /var/lib/secubox/redroid
    systemctl daemon-reload
    systemctl enable secubox-redroid.service
    systemctl start secubox-redroid.service || true
    systemctl reload nginx 2>/dev/null || true
    ;;
esac
#DEBHELPER#
