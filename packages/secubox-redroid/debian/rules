#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-redroid/usr/lib/secubox/redroid/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-redroid/usr/lib/secubox/redroid/api/
	touch $(CURDIR)/debian/secubox-redroid/usr/lib/secubox/redroid/api/__init__.py
	install -d $(CURDIR)/debian/secubox-redroid/usr/share/secubox/www/redroid
	install -m 644 www/redroid/index.html $(CURDIR)/debian/secubox-redroid/usr/share/secubox/www/redroid/
	install -d $(CURDIR)/debian/secubox-redroid/etc/nginx/secubox.d
	install -m 644 nginx/redroid.conf $(CURDIR)/debian/secubox-redroid/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-redroid/usr/share/secubox/menu.d
	install -m 644 menu.d/821-redroid.json $(CURDIR)/debian/secubox-redroid/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-redroid/usr/lib/systemd/system
	install -m 644 debian/secubox-redroid.service $(CURDIR)/debian/secubox-redroid/usr/lib/systemd/system/
