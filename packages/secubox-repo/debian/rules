#!/usr/bin/make -f
export DH_VERBOSE = 1

%:
	dh $@ --with python3

override_dh_auto_install:
	# Create directories
	install -d $(CURDIR)/debian/secubox-repo/usr/sbin
	install -d $(CURDIR)/debian/secubox-repo/usr/lib/secubox/repo/api
	install -d $(CURDIR)/debian/secubox-repo/usr/share/secubox/www/repo
	install -d $(CURDIR)/debian/secubox-repo/etc/secubox/repo
	install -d $(CURDIR)/debian/secubox-repo/etc/nginx/snippets
	install -d $(CURDIR)/debian/secubox-repo/usr/share/secubox/menu.d

	# Install repoctl
	install -m 755 sbin/repoctl $(CURDIR)/debian/secubox-repo/usr/sbin/

	# Install API
	cp -r api/* $(CURDIR)/debian/secubox-repo/usr/lib/secubox/repo/api/

	# Install web frontend
	cp -r www/repo/* $(CURDIR)/debian/secubox-repo/usr/share/secubox/www/repo/ || true

	# Install configuration templates
	cp -r conf/* $(CURDIR)/debian/secubox-repo/etc/secubox/repo/ || true
	cp -r templates/* $(CURDIR)/debian/secubox-repo/etc/secubox/repo/ || true

	# Install nginx config
	install -m 644 debian/nginx-repo.conf $(CURDIR)/debian/secubox-repo/etc/nginx/snippets/secubox-repo.conf || true

	# Install menu entry
	install -m 644 debian/menu.json $(CURDIR)/debian/secubox-repo/usr/share/secubox/menu.d/repo.json || true

override_dh_installsystemd:
	dh_installsystemd --name=secubox-repo
