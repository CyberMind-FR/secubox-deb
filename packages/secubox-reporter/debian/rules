#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-reporter/usr/lib/secubox/reporter/
	cp -r api debian/secubox-reporter/usr/lib/secubox/reporter/
	install -d debian/secubox-reporter/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-reporter/usr/share/secubox/www/ || true
	install -d debian/secubox-reporter/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-reporter/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-reporter/etc/nginx/secubox.d
	[ -f nginx/reporter.conf ] && cp nginx/reporter.conf debian/secubox-reporter/etc/nginx/secubox.d/ || true
	# Report templates directory
	install -d debian/secubox-reporter/usr/share/secubox/reporter/templates
