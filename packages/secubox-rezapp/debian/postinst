#!/bin/bash
set -e
case "$1" in
  configure)
    install -d -o root -g root -m 755 /var/lib/secubox/rezapp
    install -d -o root -g root -m 755 /var/lib/secubox/rezapp/templates
    install -d -o root -g root -m 755 /var/cache/secubox/rezapp
    systemctl daemon-reload
    systemctl enable secubox-rezapp.service
    systemctl start secubox-rezapp.service || true
    systemctl reload nginx 2>/dev/null || true
    ;;
esac
#DEBHELPER#
