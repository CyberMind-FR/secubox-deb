#!/bin/bash
set -e
case "$1" in
  remove|deconfigure)
    rm -f /etc/nginx/secubox.d/routes.conf
    systemctl reload nginx 2>/dev/null || true
    ;;
  upgrade)
    # Don't remove nginx config on upgrade, postinst will reinstall it
    ;;
esac
systemctl stop    secubox-routes.service 2>/dev/null || true
systemctl disable secubox-routes.service 2>/dev/null || true
#DEBHELPER#
