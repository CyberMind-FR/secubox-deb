#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_configure:
	# Skip configure - pure Python package

override_dh_auto_build:
	# No build needed - pure Python package

override_dh_auto_install:
	# Install API module
	install -d $(CURDIR)/debian/secubox-soc-agent/usr/lib/python3/dist-packages/secubox_soc_agent
	cp -r $(CURDIR)/api $(CURDIR)/debian/secubox-soc-agent/usr/lib/python3/dist-packages/secubox_soc_agent/
	cp -r $(CURDIR)/lib $(CURDIR)/debian/secubox-soc-agent/usr/lib/python3/dist-packages/secubox_soc_agent/
	echo "from .api.main import app" > $(CURDIR)/debian/secubox-soc-agent/usr/lib/python3/dist-packages/secubox_soc_agent/__init__.py

	# Install systemd service
	install -d $(CURDIR)/debian/secubox-soc-agent/lib/systemd/system
	install -m 644 $(CURDIR)/debian/secubox-soc-agent.service $(CURDIR)/debian/secubox-soc-agent/lib/systemd/system/

	# Create data directories
	install -d $(CURDIR)/debian/secubox-soc-agent/var/lib/secubox/soc-agent
	install -d $(CURDIR)/debian/secubox-soc-agent/var/log/secubox

override_dh_auto_clean:
	# Nothing to clean

override_dh_auto_test:
	# Skip tests during build

override_dh_installsystemd:
	dh_installsystemd --name=secubox-soc-agent
