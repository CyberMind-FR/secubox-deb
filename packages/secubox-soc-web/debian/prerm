#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Remove nginx site link
        rm -f /etc/nginx/sites-enabled/secubox-soc-web 2>/dev/null || true

        # Reload nginx if running
        if systemctl is-active --quiet nginx; then
            systemctl reload nginx || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
