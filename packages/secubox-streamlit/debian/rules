#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-streamlit/usr/lib/secubox/streamlit/
	cp -r api debian/secubox-streamlit/usr/lib/secubox/streamlit/
	install -d debian/secubox-streamlit/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-streamlit/usr/share/secubox/www/ || true
	install -d debian/secubox-streamlit/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-streamlit/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-streamlit/etc/nginx/secubox.d
	[ -f nginx/streamlit.conf ] && cp nginx/streamlit.conf debian/secubox-streamlit/etc/nginx/secubox.d/ || true
	# Install control scripts
	install -d debian/secubox-streamlit/usr/sbin
	[ -d sbin ] && install -m 755 sbin/* debian/secubox-streamlit/usr/sbin/ || true
	[ -d scripts ] && install -m 755 scripts/* debian/secubox-streamlit/usr/sbin/ || true
