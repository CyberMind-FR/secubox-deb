#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-torrent/usr/lib/secubox/torrent/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-torrent/usr/lib/secubox/torrent/api/
	touch $(CURDIR)/debian/secubox-torrent/usr/lib/secubox/torrent/api/__init__.py
	install -d $(CURDIR)/debian/secubox-torrent/usr/share/secubox/www/torrent
	install -m 644 www/torrent/index.html $(CURDIR)/debian/secubox-torrent/usr/share/secubox/www/torrent/
	install -d $(CURDIR)/debian/secubox-torrent/etc/nginx/secubox.d
	install -m 644 nginx/torrent.conf $(CURDIR)/debian/secubox-torrent/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-torrent/usr/share/secubox/menu.d
	install -m 644 menu.d/815-torrent.json $(CURDIR)/debian/secubox-torrent/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-torrent/usr/lib/systemd/system
	install -m 644 debian/secubox-torrent.service $(CURDIR)/debian/secubox-torrent/usr/lib/systemd/system/
