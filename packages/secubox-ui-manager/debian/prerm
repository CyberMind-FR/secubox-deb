#!/bin/bash
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop services
        systemctl stop secubox-ui-manager.service 2>/dev/null || true
        systemctl stop secubox-ui-health.timer 2>/dev/null || true
        ;;

    failed-upgrade)
        ;;

    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
