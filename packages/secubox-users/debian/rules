#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	# API
	install -d debian/secubox-users/usr/lib/secubox/users
	cp -r api debian/secubox-users/usr/lib/secubox/users/
	# CLI controller
	install -d debian/secubox-users/usr/sbin
	install -m 755 sbin/usersctl debian/secubox-users/usr/sbin/
	# Frontend
	install -d debian/secubox-users/usr/share/secubox/www/users
	cp -r www/users/. debian/secubox-users/usr/share/secubox/www/users/
	# Menu
	install -d debian/secubox-users/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-users/usr/share/secubox/menu.d/ || true
	# Nginx config
	install -d debian/secubox-users/etc/nginx/secubox.d
	[ -f nginx/users.conf ] && cp nginx/users.conf debian/secubox-users/etc/nginx/secubox.d/ || true
	# Users data directory
	install -d debian/secubox-users/etc/secubox
