[Unit]
Description=SecuBox VM API
After=network.target secubox-core.service

[Service]
Type=simple
User=root
WorkingDirectory=/usr/lib/secubox/vm
ExecStart=/usr/local/bin/uvicorn api.main:app --uds /run/secubox/vm.sock --log-level warning
UMask=0117
Restart=on-failure

[Install]
WantedBy=multi-user.target
