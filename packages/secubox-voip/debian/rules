#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	# API files
	install -d debian/secubox-voip/usr/lib/secubox/voip/
	cp -r api debian/secubox-voip/usr/lib/secubox/voip/
	# Static www files
	install -d debian/secubox-voip/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-voip/usr/share/secubox/www/ || true
	# Menu definitions
	install -d debian/secubox-voip/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-voip/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-voip/etc/nginx/secubox.d
	[ -f nginx/voip.conf ] && cp nginx/voip.conf debian/secubox-voip/etc/nginx/secubox.d/ || true
	# Systemd service
	install -d debian/secubox-voip/lib/systemd/system
	[ -f systemd/secubox-voip.service ] && cp systemd/secubox-voip.service debian/secubox-voip/lib/systemd/system/ || true
