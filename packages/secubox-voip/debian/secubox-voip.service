[Unit]
Description=SecuBox VoIP API
After=network.target secubox-core.service

[Service]
Type=simple
User=root
WorkingDirectory=/usr/lib/secubox/voip
ExecStart=/usr/bin/uvicorn api.main:app --uds /run/secubox/voip.sock --log-level warning
UMask=0117
Restart=on-failure

[Install]
WantedBy=multi-user.target
