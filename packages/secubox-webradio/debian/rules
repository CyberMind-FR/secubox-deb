#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d $(CURDIR)/debian/secubox-webradio/usr/lib/secubox/webradio/api
	install -m 644 api/main.py $(CURDIR)/debian/secubox-webradio/usr/lib/secubox/webradio/api/
	touch $(CURDIR)/debian/secubox-webradio/usr/lib/secubox/webradio/api/__init__.py
	install -d $(CURDIR)/debian/secubox-webradio/usr/share/secubox/www/webradio
	install -m 644 www/webradio/index.html $(CURDIR)/debian/secubox-webradio/usr/share/secubox/www/webradio/
	install -d $(CURDIR)/debian/secubox-webradio/etc/nginx/secubox.d
	install -m 644 nginx/webradio.conf $(CURDIR)/debian/secubox-webradio/etc/nginx/secubox.d/
	install -d $(CURDIR)/debian/secubox-webradio/usr/share/secubox/menu.d
	install -m 644 menu.d/813-webradio.json $(CURDIR)/debian/secubox-webradio/usr/share/secubox/menu.d/
	install -d $(CURDIR)/debian/secubox-webradio/usr/lib/systemd/system
	install -m 644 debian/secubox-webradio.service $(CURDIR)/debian/secubox-webradio/usr/lib/systemd/system/
