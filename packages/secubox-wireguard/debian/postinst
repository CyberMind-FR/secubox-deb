#!/bin/sh
set -e

case "$1" in
    configure)
        # Add www-data to secubox group for nginx access
        usermod -a -G secubox www-data 2>/dev/null || true
        
        # Create data directories
        mkdir -p /var/lib/secubox/wireguard/peers
        chown -R secubox:secubox /var/lib/secubox/wireguard
        
        # Enable and start service
        systemctl daemon-reload
        systemctl enable secubox-wireguard.service
        systemctl start secubox-wireguard.service || true
        
        # Reload nginx if running
        systemctl reload nginx 2>/dev/null || true
        ;;
esac

#DEBHELPER#

exit 0
