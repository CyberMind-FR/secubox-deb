#!/bin/bash
set -e
case "$1" in
  remove|upgrade)
    rm -f /etc/nginx/secubox.d/wireguard.conf
    systemctl stop    secubox-wireguard.service 2>/dev/null || true
    systemctl disable secubox-wireguard.service 2>/dev/null || true
    systemctl reload nginx 2>/dev/null || true
    ;;
esac
#DEBHELPER#
