#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	install -d debian/secubox-wireguard/usr/lib/secubox/wireguard/
	cp -r api debian/secubox-wireguard/usr/lib/secubox/wireguard/
	install -d debian/secubox-wireguard/usr/share/secubox/www
	[ -d www ] && cp -r www/. debian/secubox-wireguard/usr/share/secubox/www/ || true
	install -d debian/secubox-wireguard/usr/share/secubox/menu.d
	[ -d menu.d ] && cp -r menu.d/. debian/secubox-wireguard/usr/share/secubox/menu.d/ || true
	# Modular nginx config
	install -d debian/secubox-wireguard/etc/nginx/secubox.d
	[ -f nginx/wireguard.conf ] && cp nginx/wireguard.conf debian/secubox-wireguard/etc/nginx/secubox.d/ || true
	# Install control scripts
	install -d debian/secubox-wireguard/usr/sbin
	[ -d sbin ] && install -m 755 sbin/* debian/secubox-wireguard/usr/sbin/ || true
	# Create data directories
	install -d debian/secubox-wireguard/var/lib/secubox/wireguard/peers
