#!/usr/bin/env python3
import pigpio
import time
import sys

CLK = 11
MOSI = 10
CS = 18
BL = 19
DELAY = 0.00001

def main():
    print('HyperPixel 2.1 Round - Initializing ST7701S LCD via pigpio...')
    pi = pigpio.pi()
    if not pi.connected:
        print('ERROR: Cannot connect to pigpiod.')
        sys.exit(1)

    pi.set_mode(CLK, pigpio.OUTPUT)
    pi.set_mode(MOSI, pigpio.OUTPUT)
    pi.set_mode(CS, pigpio.OUTPUT)
    pi.set_mode(BL, pigpio.OUTPUT)
    pi.write(CLK, 0)
    pi.write(CS, 1)
    pi.write(BL, 1)

    def sendBits(data, numBits=8):
        data <<= (9 - numBits)
        for bit in range(numBits):
            pi.write(MOSI, 1 if data & 0x100 else 0)
            data <<= 1
            time.sleep(DELAY)
            pi.write(CLK, 1)
            time.sleep(DELAY)
            pi.write(CLK, 0)
        pi.write(MOSI, 0)

    def SPI_Write(output): sendBits(output, 9)
    def SPI_WriteComm(b): SPI_Write(b)
    def SPI_WriteData(b): SPI_Write(b | 0x100)
    def Delay(ms): time.sleep(ms / 1000.0)

    pi.write(CS, 0)
    SPI_WriteComm(0x01); Delay(240)
    SPI_WriteComm(0xFF); SPI_WriteData(0x77); SPI_WriteData(0x01); SPI_WriteData(0x00); SPI_WriteData(0x00); SPI_WriteData(0x10)
    SPI_WriteComm(0xC0); SPI_WriteData(0x3B); SPI_WriteData(0x00)
